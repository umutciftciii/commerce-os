# TD-036 (ADR-057) — Env parsing kurali:
#   * OPSIYONEL degerler bos birakilabilir (`KEY=`): bos/yalniz-bosluk deger
#     "yok" sayilir ve varsayilana/undefined'a duser; config yuklemesi COKMEZ.
#   * ZORUNLU degerler (DATABASE_URL, REDIS_URL, INTERNAL_API_TOKEN,
#     SESSION_SECRET) strict'tir: eksik/gecersizse boot YUKSEK SESLE hata verir.
#   * Opsiyonel bir alana bos OLMAYAN GECERSIZ deger verilirse yine hata verilir.
#   * Bu dosyaya GERCEK secret yazmayin; yalniz placeholder/dev degerleri.
APP_ENV=development
SERVICE_NAME=api-gateway
LOG_LEVEL=info
DATABASE_URL=postgresql://commerce_os:commerce_os_password@127.0.0.1:5432/commerce_os?schema=public
REDIS_URL=redis://127.0.0.1:6379
INTERNAL_API_TOKEN=replace-with-local-internal-token
SESSION_SECRET=replace-with-local-session-secret-32-chars-min
SESSION_TTL_SECONDS=28800
PASSWORD_HASH_PEPPER=
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
ADMIN_SESSION_COOKIE_NAME=commerce_os_admin_session
ADMIN_AUTH_COOKIE_NAME=commerce_os_admin_session
ADMIN_CSRF_COOKIE_NAME=commerce_os_admin_csrf
ADMIN_CSRF_HEADER_NAME=x-commerce-os-csrf
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_SAME_SITE=lax
# store-admin-web (Faz 2B) — store-admin'e ozel cookie adlari (ADMIN_COOKIE_SECURE/SAME_SITE paylasilir).
# CSRF header adi admin-web ile ortaktir (ADMIN_CSRF_HEADER_NAME).
STORE_ADMIN_SESSION_COOKIE_NAME=commerce_os_store_admin_session
STORE_ADMIN_CSRF_COOKIE_NAME=commerce_os_store_admin_csrf
# Demo store context: store-user auth gelene kadar hedef mağaza slug'i (yoksa listenin ilk mağazasi).
STORE_ADMIN_DEMO_STORE_SLUG=demo-store
# storefront-web (Faz 3A.1 / TD-032) — public vitrin katalog cozumleyici.
# Vitrin, katalog verisini gateway'in AUTH GEREKTIRMEYEN public-read uclarindan
# (`/public/stores/:slug/...`) token'siz okur. Platform-admin login/token YOK;
# yalnizca cozulecek demo mağaza slug'i tutulur.
STOREFRONT_DEMO_STORE_SLUG=demo-store
# storefront-web (Faz 3B.1) — sepet cookie imza anahtari. Server-only (httpOnly
# imza); NEXT_PUBLIC degil, client bundle'a girmez. Sepet yalnizca {variantId,
# quantity} referansi tutar; guvenlik nihai olarak order aninda sunucu-tarafi
# yeniden dogrulamaya dayanir. Uretimde gizli bir degerle override edilmeli.
STOREFRONT_CART_SECRET=storefront-dev-cart-secret
API_GATEWAY_PORT=4000
WORKER_CONCURRENCY=5

# api-gateway (Faz 3B.2) — payment provider credential encryption-at-rest anahtari.
# AES-256-GCM icin 32 byte (base64 ya da 64 karakterlik hex). Bos birakilirsa
# development/test'te SABIT GUVENSIZ dev fallback kullanilir (loglara yuksek sesli
# uyari yazilir). staging/production'da eksikse odeme sifreleme islemi hata verir.
# Uretimde mutlaka gizli bir degerle override edin. Ornek: `openssl rand -base64 32`
PAYMENT_ENCRYPTION_KEY=
# api-gateway (Faz 3B.2) — gercek provider sandbox/live HTTP cagrilarini acar.
# Varsayilan KAPALI: provider adapter'lari (iyzico/Stripe/PayTR/generic) request/
# response/status mapping'i URETIR ama transport kapaliyken canli cagri YAPMAZ
# (SANDBOX_HTTP_DISABLED doner). Saglayici sozlesmesi + TEST credential sonrasi
# true yapilarak AYNI adapter aktive edilir. MOCK saglayici bu flag'den bagimsizdir.
PAYMENT_SANDBOX_HTTP_ENABLED=false

# api-gateway (F3C.1 Shipping) — kargo credential sifreleme anahtari. AES-256-GCM
# icin 32 byte (base64 ya da 64 karakterlik hex). Payment'tan AYRI domain anahtaridir;
# PAYMENT_ENCRYPTION_KEY'e FALLBACK YOKTUR. Bos birakilirsa HICBIR ortamda guvensiz
# fallback kullanilmaz: kargo credential save/test/decrypt islemleri CONFIG_MISSING
# doner. Uretimde mutlaka gizli bir degerle override edin. Ornek: `openssl rand -base64 32`
SHIPPING_ENCRYPTION_KEY=
# api-gateway (F3C.1) — gercek kargo saglayici sandbox/live HTTP cagrilarini acar.
# Varsayilan KAPALI: DHL/Geliver adapter'lari request mapping URETIR ama transport
# kapaliyken canli cagri YAPMAZ (SHIPPING_HTTP_DISABLED doner). MOCK bu flag'den bagimsiz.
# TODO-094B safe verification: bu flag true iken bile destructive guard'lar (asagidaki
# *_ALLOW_*) KAPALI kaldigi surece createOrder/createbarcode/acceptOffer 409 doner; yalniz
# Identity/CBS/calculate/createTest gibi read/quote/test cagrilari yapilir. Gercek credential
# degerleri repo DISINDAKI gizli dosyadan okunur (or. .secrets/commerce-os-shipping.local.env);
# bu repoya/loglara/snapshot'a ASLA yazilmaz.
SHIPPING_SANDBOX_HTTP_ENABLED=false
# F3C.1 — DHL eCommerce destructive operasyon + Geliver etiket satin alma guard'lari.
# Hepsi varsayilan KAPALI. Canli createOrder/createbarcode/acceptOffer ancak ilgili
# flag true + providerConfig.allow* true + request explicitConfirm true uclusu saglaninca
# calisir; aksi halde 409 (ORDER_CREATE_DISABLED / BARCODE_CREATE_DISABLED / LABEL_PURCHASE_DISABLED).
DHL_ECOMMERCE_ALLOW_RECIPIENT_CREATE=false
DHL_ECOMMERCE_ALLOW_ORDER_CREATE=false
DHL_ECOMMERCE_ALLOW_BARCODE_CREATE=false
DHL_ECOMMERCE_ALLOW_CANCEL=false
GELIVER_ALLOW_LABEL_PURCHASE=false
# F3C.1/F3C.6 — DHL eCommerce (teknik: MNG Kargo, IBM API Connect) host secimi.
# providerConfig.mode=TEST ise TEST base URL kullanilir; TANIMSIZSA TEST istegi YAPILMAZ
# (TEST_BASE_URL_MISSING, canli host'a fallback YOK). Sandbox: https://testapi.mngkargo.com.tr
DHL_ECOMMERCE_TEST_BASE_URL=https://testapi.mngkargo.com.tr
DHL_ECOMMERCE_LIVE_BASE_URL=https://api.mngkargo.com.tr
# IBM API Connect surum header'i (x-api-version); sandbox/canli isteklerde gonderilir. Ornek: 1.0
DHL_ECOMMERCE_API_VERSION=
# F3C.3 — Saglayici HTTP cagri timeout'u (ms). MNG sandbox bazi operasyon cagrilarinda
# ~15s surebildiginden default 60s. Timeout asilinca SHIPPING_HTTP_TIMEOUT (504) doner.
DHL_ECOMMERCE_HTTP_TIMEOUT_MS=60000
# TODO-128 — Kargo saglayici webhook'larinin (POST /public/shipping/webhooks/:token)
# ULASILDIGI public taban URL. Store-admin panelde saglayiciya yapistirilacak tam
# webhook URL'si bu tabandan uretilir. Tanimsizsa panel "public base URL ayarlanmali"
# uyarisi gosterir (URL uretmez). Secret DEGILDIR; yalniz erisim adresidir. Yol parcasi
# olan token ayrica gizli tutulur ve HMAC imza her istekte zorunludur. Ornek (canli):
# https://api.cmddigital.com  (yerel: http://localhost:4000)
PUBLIC_WEBHOOK_BASE_URL=

# TODO-129 — Zamanlanmis shipment sync worker'i (provider-agnostic; api-gateway icinde calisir).
# Varsayilan KAPALI: acilinca terminal olmayan gonderiler periyodik olarak saglayici
# tracking/status sorgusuyla senkronlanir (yalniz sync destekleyen saglayicilar; digerleri
# guvenle atlanir). Manuel sync-all ucu her durumda calismaya devam eder. Tum degerler
# bos birakilabilir (`KEY=`); bos deger varsayilana duser, config yuklemesi COKMEZ.
SHIPMENT_SYNC_ENABLED=false
# Tur araligi (saniye, min 30; muhafazakar varsayilan 300 = 5 dk).
SHIPMENT_SYNC_INTERVAL_SECONDS=300
# Tur basina en fazla kac gonderi senkronlanir (varsayilan 25).
SHIPMENT_SYNC_BATCH_SIZE=25
# Ayni gonderi en erken bu sure sonra yeniden senkronlanir (dakika, varsayilan 15).
SHIPMENT_SYNC_STALE_AFTER_MINUTES=15
# Ardisik hata esigi: bu sayiya ulasan gonderiyi zamanlanmis worker SECMEZ
# (manuel sync-all calisir ve basarili sync sayaci sifirlar). Varsayilan 10.
SHIPMENT_SYNC_MAX_ATTEMPTS=10

# TODO-123 — Barkod retry/backoff worker'i (provider-agnostic; api-gateway icinde calisir).
# Varsayilan KAPALI (docker dev'de de acilmaz — MNG sandbox'i duzenli cagirmamak icin).
# Acilinca yalniz TRANSIENT (timeout/5xx/network) barkod hatasi olan gonderiler ussel backoff
# ile YENIDEN barkod olusturmaya calisir. DATA_FIX (varis/adres eslemesi) ve TERMINAL hatalar
# OTOMATIK denenmez; admin duzeltmesi (TODO-124/139) bekler. Manuel "Barkod/Etiket Olustur"
# worker kapaliyken de calisir ve backoff'u bypass eder. Tum degerler bos birakilabilir (`KEY=`).
BARCODE_RETRY_ENABLED=false
# Tur araligi (saniye, min 30; muhafazakar varsayilan 300 = 5 dk).
BARCODE_RETRY_INTERVAL_SECONDS=300
# Tur basina en fazla kac gonderi denenir (varsayilan 10; retry gurultulu/pahali olmasin).
BARCODE_RETRY_BATCH_SIZE=10
# Ussel backoff tabani (dakika): stale * 2^(deneme-1), 6 saatle sinirli. Varsayilan 15.
BARCODE_RETRY_STALE_AFTER_MINUTES=15
# Ardisik transient hata esigi: bu sayiya ulasan gonderiyi worker SECMEZ (MAX_ATTEMPTS blok;
# manuel "Simdi Tekrar Dene" calisir). Varsayilan 5.
BARCODE_RETRY_MAX_ATTEMPTS=5

# Frontend apps (admin-web, store-admin-web, storefront-web)
# Base URL the API client uses to reach the API gateway.
API_GATEWAY_URL=http://localhost:4000
