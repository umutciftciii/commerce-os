APP_ENV=development
SERVICE_NAME=api-gateway
LOG_LEVEL=info
DATABASE_URL=postgresql://commerce_os:commerce_os_password@127.0.0.1:5432/commerce_os?schema=public
REDIS_URL=redis://127.0.0.1:6379
INTERNAL_API_TOKEN=replace-with-local-internal-token
SESSION_SECRET=replace-with-local-session-secret-32-chars-min
SESSION_TTL_SECONDS=28800
PASSWORD_HASH_PEPPER=
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
ADMIN_SESSION_COOKIE_NAME=commerce_os_admin_session
ADMIN_AUTH_COOKIE_NAME=commerce_os_admin_session
ADMIN_CSRF_COOKIE_NAME=commerce_os_admin_csrf
ADMIN_CSRF_HEADER_NAME=x-commerce-os-csrf
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_SAME_SITE=lax
# store-admin-web (Faz 2B) — store-admin'e ozel cookie adlari (ADMIN_COOKIE_SECURE/SAME_SITE paylasilir).
# CSRF header adi admin-web ile ortaktir (ADMIN_CSRF_HEADER_NAME).
STORE_ADMIN_SESSION_COOKIE_NAME=commerce_os_store_admin_session
STORE_ADMIN_CSRF_COOKIE_NAME=commerce_os_store_admin_csrf
# Demo store context: store-user auth gelene kadar hedef mağaza slug'i (yoksa listenin ilk mağazasi).
STORE_ADMIN_DEMO_STORE_SLUG=demo-store
# storefront-web (Faz 3A.1 / TD-032) — public vitrin katalog cozumleyici.
# Vitrin, katalog verisini gateway'in AUTH GEREKTIRMEYEN public-read uclarindan
# (`/public/stores/:slug/...`) token'siz okur. Platform-admin login/token YOK;
# yalnizca cozulecek demo mağaza slug'i tutulur.
STOREFRONT_DEMO_STORE_SLUG=demo-store
# storefront-web (Faz 3B.1) — sepet cookie imza anahtari. Server-only (httpOnly
# imza); NEXT_PUBLIC degil, client bundle'a girmez. Sepet yalnizca {variantId,
# quantity} referansi tutar; guvenlik nihai olarak order aninda sunucu-tarafi
# yeniden dogrulamaya dayanir. Uretimde gizli bir degerle override edilmeli.
STOREFRONT_CART_SECRET=storefront-dev-cart-secret
API_GATEWAY_PORT=4000
WORKER_CONCURRENCY=5

# api-gateway (Faz 3B.2) — payment provider credential encryption-at-rest anahtari.
# AES-256-GCM icin 32 byte (base64 ya da 64 karakterlik hex). Bos birakilirsa
# development/test'te SABIT GUVENSIZ dev fallback kullanilir (loglara yuksek sesli
# uyari yazilir). staging/production'da eksikse odeme sifreleme islemi hata verir.
# Uretimde mutlaka gizli bir degerle override edin. Ornek: `openssl rand -base64 32`
PAYMENT_ENCRYPTION_KEY=
# api-gateway (Faz 3B.2) — gercek provider sandbox/live HTTP cagrilarini acar.
# Varsayilan KAPALI: provider adapter'lari (iyzico/Stripe/PayTR/generic) request/
# response/status mapping'i URETIR ama transport kapaliyken canli cagri YAPMAZ
# (SANDBOX_HTTP_DISABLED doner). Saglayici sozlesmesi + TEST credential sonrasi
# true yapilarak AYNI adapter aktive edilir. MOCK saglayici bu flag'den bagimsizdir.
PAYMENT_SANDBOX_HTTP_ENABLED=false

# Frontend apps (admin-web, store-admin-web, storefront-web)
# Base URL the API client uses to reach the API gateway.
API_GATEWAY_URL=http://localhost:4000
