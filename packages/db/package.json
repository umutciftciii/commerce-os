{
  "name": "@commerce-os/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "node scripts/seed.mjs",
    "db:verify-seed": "node scripts/verify-seed.mjs",
    "db:seed-enterprise": "node scripts/enterprise-seed.mjs",
    "db:seed-enterprise:dry": "node scripts/enterprise-seed.mjs --dry-run",
    "db:verify-enterprise": "node scripts/verify-enterprise-seed.mjs",
    "db:audit-primary-category": "node scripts/audit-primary-category.mjs",
    "db:cleanup-smoke": "tsx scripts/cleanup-smoke.ts"
  },
  "dependencies": {
    "@commerce-os/auth": "workspace:*",
    "@commerce-os/theme": "workspace:*",
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "tsx": "^4.19.2"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  }
}
