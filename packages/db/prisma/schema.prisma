generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformUserRole {
  SUPER_ADMIN
  SUPPORT_ADMIN
}

enum StoreUserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum StoreStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  CLOSED
}

enum DomainType {
  SYSTEM_SUBDOMAIN
  CUSTOM_DOMAIN
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SYSTEM
}

enum EventType {
  STORE_CREATED
  STORE_UPDATED
  USER_INVITED
  SUBSCRIPTION_CHANGED
  SYSTEM_EVENT
}

enum QueueJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
}

enum ProductSalesMode {
  ONLINE
  INQUIRY
  APPOINTMENT
  WHATSAPP
  CATALOG_ONLY
}

enum ProductPriceVisibility {
  VISIBLE
  HIDDEN
  STARTING_FROM
  ON_REQUEST
}

enum ProductPrimaryAction {
  ADD_TO_CART
  REQUEST_PRICE
  BOOK_APPOINTMENT
  WHATSAPP
  CONTACT_FORM
  NONE
}

enum ProductCategoryStatus {
  ACTIVE
  ARCHIVED
}

enum ProductVariantStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryMovementType {
  ADJUSTMENT
  SALE_RESERVATION
  SALE_RELEASE
  RETURN
  IMPORT
}

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum OrderStatus {
  DRAFT
  PLACED
  CONFIRMED
  CANCELLED
  FULFILLED
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
  CANCELLED
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

enum PaymentProviderType {
  MOCK
  IYZICO
  STRIPE
  PAYTR
  GENERIC_REDIRECT
}

enum PaymentProviderMode {
  TEST
  LIVE
}

enum PaymentMethodType {
  CARD
  BANK_TRANSFER
  CASH_ON_DELIVERY
  PAYMENT_LINK
}

enum PaymentProviderStatus {
  ENABLED
  DISABLED
}

enum ThreeDsMode {
  DISABLED
  OPTIONAL
  REQUIRED
}

enum PaymentAttemptStatus {
  CREATED
  PENDING
  REQUIRES_ACTION
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProviderEventType {
  PAYMENT_CREATED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PAYMENT_CANCELLED
  PAYMENT_REFUNDED
  WEBHOOK_RECEIVED
  CONNECTION_TEST
  STATUS_CHANGED
}

model PlatformUser {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String
  role         PlatformUserRole @default(SUPPORT_ADMIN)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  storeUsers StoreUser[]
  auditLogs  AuditLog[]
  sessions   PlatformSession[]
}

model PlatformSession {
  id             String    @id @default(cuid())
  platformUserId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@index([expiresAt])
}

model Store {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  status    StoreStatus @default(DRAFT)
  metadata  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users         StoreUser[]
  domains       StoreDomain[]
  subscriptions Subscription[]
  products      Product[]
  variants      ProductVariant[]
  categories    ProductCategory[]
  inventory     InventoryItem[]
  movements     InventoryMovement[]
  customers     Customer[]
  customerAddresses CustomerAddress[]
  orders        Order[]
  orderLines    OrderLine[]
  orderAddresses OrderAddress[]
  orderEvents   OrderEvent[]
  orderCounters OrderNumberCounter[]
  reservations  InventoryReservation[]
  auditLogs     AuditLog[]
  eventLogs     EventLog[]
  queueJobLogs  QueueJobLog[]
  paymentProviderConfigs PaymentProviderConfig[]
  paymentAttempts        PaymentAttempt[]
  paymentProviderEvents  PaymentProviderEvent[]
}

model StoreUser {
  id             String        @id @default(cuid())
  storeId        String
  userId         String
  role           StoreUserRole @default(VIEWER)
  invitedAt      DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
}

model StoreDomain {
  id        String       @id @default(cuid())
  storeId   String
  domain    String       @unique
  type      DomainType   @default(SYSTEM_SUBDOMAIN)
  status    DomainStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Plan {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  storeId   String
  planId    String
  status    SubscriptionStatus @default(TRIALING)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  metadata  Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  plan  Plan  @relation(fields: [planId], references: [id])

  @@index([storeId])
  @@index([planId])
}

model AuditLog {
  id             String      @id @default(cuid())
  storeId        String?
  platformUserId String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  store        Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([platformUserId])
}

model EventLog {
  id        String    @id @default(cuid())
  storeId   String?
  type      EventType
  payload   Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([type])
}

model QueueJobLog {
  id        String         @id @default(cuid())
  storeId   String?
  jobName   String
  queueName String
  status    QueueJobStatus @default(PENDING)
  attempts  Int            @default(0)
  payload   Json?
  error     Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([queueName, jobName])
  @@index([status])
}

model Product {
  id                      String                 @id @default(cuid())
  storeId                 String
  title                   String
  slug                    String
  description             String?
  status                  ProductStatus          @default(DRAFT)
  type                    ProductType            @default(PHYSICAL)
  vendor                  String?
  brand                   String?
  seoTitle                String?
  seoDescription          String?
  salesMode               ProductSalesMode       @default(ONLINE)
  priceVisibility         ProductPriceVisibility @default(VISIBLE)
  primaryAction           ProductPrimaryAction   @default(ADD_TO_CART)
  inquiryEnabled          Boolean                @default(false)
  appointmentRequired     Boolean                @default(false)
  whatsappEnabled         Boolean                @default(false)
  purchasable             Boolean                @default(true)
  minOrderQuantity        Int                    @default(1)
  maxOrderQuantity        Int?
  callToActionLabel       String?
  whatsappMessageTemplate String?
  inquiryFormTitle        String?
  appointmentNote         String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  store       Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants    ProductVariant[]
  assignments ProductCategoryAssignment[]
  orderLines  OrderLine[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([status])
  @@index([salesMode])
  @@index([purchasable])
}

model ProductVariant {
  id             String               @id @default(cuid())
  productId      String
  storeId        String
  title          String
  sku            String
  barcode        String?
  priceMinor     Int
  compareAtMinor Int?
  currency       String
  status         ProductVariantStatus @default(ACTIVE)
  optionValues   Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventory InventoryItem?
  movements InventoryMovement[]
  orderLines OrderLine[]
  reservations InventoryReservation[]

  @@unique([storeId, sku])
  @@index([productId])
  @@index([storeId])
  @@index([status])
}

model ProductCategory {
  id        String                @id @default(cuid())
  storeId   String
  name      String
  slug      String
  parentId  String?
  sortOrder Int                   @default(0)
  status    ProductCategoryStatus @default(ACTIVE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  store       Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent      ProductCategory?            @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[]           @relation("ProductCategoryTree")
  assignments ProductCategoryAssignment[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([parentId])
  @@index([status])
}

model ProductCategoryAssignment {
  productId  String
  categoryId String
  storeId    String
  createdAt  DateTime @default(now())

  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@unique([storeId, productId, categoryId])
  @@index([storeId])
  @@index([categoryId])
}

model InventoryItem {
  id                String   @id @default(cuid())
  storeId           String
  variantId         String   @unique
  quantityOnHand    Int      @default(0)
  quantityReserved  Int      @default(0)
  lowStockThreshold Int?
  updatedAt         DateTime @updatedAt

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([variantId])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  storeId       String
  variantId     String
  type          InventoryMovementType @default(ADJUSTMENT)
  quantityDelta Int
  reason        String?
  referenceType String?
  referenceId   String?
  actorUserId   String?
  createdAt     DateTime              @default(now())

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([variantId])
  @@index([type])
}

model Customer {
  id        String         @id @default(cuid())
  storeId   String
  email     String
  firstName String?
  lastName  String?
  phone     String?
  status    CustomerStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  store     Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  addresses CustomerAddress[]
  orders    Order[]

  @@unique([storeId, email])
  @@index([storeId])
  @@index([status])
}

model CustomerAddress {
  id           String      @id @default(cuid())
  storeId      String
  customerId   String
  type         AddressType
  fullName     String
  phone        String?
  countryCode  String
  city         String
  district     String?
  addressLine1 String
  addressLine2 String?
  postalCode   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([type])
}

model OrderNumberCounter {
  id        String   @id @default(cuid())
  storeId   String   @unique
  nextValue Int      @default(1)
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Order {
  id                String            @id @default(cuid())
  storeId           String
  orderNumber       String
  customerId        String?
  customerEmail     String
  currency          String
  status            OrderStatus       @default(DRAFT)
  paymentStatus     PaymentStatus     @default(UNPAID)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  subtotalAmount    Int               @default(0)
  discountAmount    Int               @default(0)
  shippingAmount    Int               @default(0)
  taxAmount         Int               @default(0)
  totalAmount       Int               @default(0)
  placedAt          DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  store        Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines        OrderLine[]
  addresses    OrderAddress[]
  events       OrderEvent[]
  reservations InventoryReservation[]
  paymentAttempts PaymentAttempt[]
  paymentEvents   PaymentProviderEvent[]

  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([customerId])
  @@index([status])
}

model OrderLine {
  id              String   @id @default(cuid())
  storeId         String
  orderId         String
  productId       String
  variantId       String
  sku             String
  title           String
  variantTitle    String
  quantity        Int
  unitPriceAmount Int
  totalAmount     Int
  currency        String
  createdAt       DateTime @default(now())

  store        Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant      ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  reservations InventoryReservation[]

  @@index([storeId])
  @@index([orderId])
  @@index([variantId])
}

model OrderAddress {
  id           String      @id @default(cuid())
  storeId      String
  orderId      String
  type         AddressType
  fullName     String
  phone        String?
  countryCode  String
  city         String
  district     String?
  addressLine1 String
  addressLine2 String?
  postalCode   String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([type])
}

model OrderEvent {
  id          String   @id @default(cuid())
  storeId     String
  orderId     String
  type        String
  message     String?
  metadata    Json?
  actorUserId String?
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([type])
}

model InventoryReservation {
  id          String                     @id @default(cuid())
  storeId     String
  orderId     String
  orderLineId String
  variantId   String
  quantity    Int
  status      InventoryReservationStatus @default(ACTIVE)
  expiresAt   DateTime?
  releasedAt  DateTime?
  consumedAt  DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLine OrderLine      @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([storeId])
  @@index([orderId])
  @@index([orderLineId])
  @@index([variantId])
  @@index([status])
}

// F3B.2 Payment Operations Foundation.
// Saglayici credential'lari yalniz ciphertext (apiKeyCipher/secretKeyCipher/
// webhookSecretCipher) olarak saklanir; duz metin DB'ye asla yazilmaz, client'a
// asla maskesiz donmez. Canli odeme bu fazda YOK; provider-ready operasyon katmani.
model PaymentProviderConfig {
  id                  String                @id @default(cuid())
  storeId             String
  provider            PaymentProviderType
  displayName         String
  status              PaymentProviderStatus @default(DISABLED)
  mode                PaymentProviderMode   @default(TEST)
  priority            Int                   @default(100)
  supportedMethods    PaymentMethodType[]
  supportedCurrencies String[]
  minAmount           Int?
  maxAmount           Int?
  threeDsMode         ThreeDsMode           @default(DISABLED)
  installmentEnabled  Boolean               @default(false)
  fallbackEnabled     Boolean               @default(false)
  merchantId          String?
  callbackUrl         String?
  apiKeyCipher        String?
  secretKeyCipher     String?
  webhookSecretCipher String?
  lastTestStatus      String?
  lastTestMessage     String?
  lastTestAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  store    Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  attempts PaymentAttempt[]
  events   PaymentProviderEvent[]

  @@unique([storeId, provider, mode])
  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, priority])
}

model PaymentAttempt {
  id                  String               @id @default(cuid())
  storeId             String
  orderId             String
  providerConfigId    String
  provider            PaymentProviderType
  mode                PaymentProviderMode
  method              PaymentMethodType
  amount              Int
  currency            String
  status              PaymentAttemptStatus @default(CREATED)
  threeDsApplied      Boolean              @default(false)
  scenario            String?
  providerReference   String?
  failureCode         String?
  failureMessage      String?
  // Kisa omurlu public odeme erisim token'inin hash'i; plain token DB'ye yazilmaz.
  accessTokenHash     String?
  accessTokenExpiresAt DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerConfig PaymentProviderConfig  @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  events         PaymentProviderEvent[]

  @@index([storeId])
  @@index([orderId])
  @@index([providerConfigId])
  @@index([status])
  @@index([accessTokenHash])
}

model PaymentProviderEvent {
  id               String                   @id @default(cuid())
  storeId          String
  providerConfigId String?
  attemptId        String?
  orderId          String?
  provider         PaymentProviderType
  type             PaymentProviderEventType
  // Provider/webhook external event id varsa set edilir; internal eventlerde null.
  eventId          String?
  message          String?
  metadata         Json?
  createdAt        DateTime                 @default(now())

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  providerConfig PaymentProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  attempt        PaymentAttempt?        @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  order          Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([storeId, provider, eventId], map: "payment_provider_event_unique_external_event")
  @@index([storeId])
  @@index([providerConfigId])
  @@index([attemptId])
  @@index([orderId])
  @@index([type])
}
