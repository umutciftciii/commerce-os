generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformUserRole {
  SUPER_ADMIN
  SUPPORT_ADMIN
}

enum StoreUserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum StoreStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  CLOSED
}

enum DomainType {
  SYSTEM_SUBDOMAIN
  CUSTOM_DOMAIN
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SYSTEM
}

enum EventType {
  STORE_CREATED
  STORE_UPDATED
  USER_INVITED
  SUBSCRIPTION_CHANGED
  SYSTEM_EVENT
}

enum QueueJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
}

enum ProductSalesMode {
  ONLINE
  INQUIRY
  APPOINTMENT
  WHATSAPP
  CATALOG_ONLY
}

enum ProductPriceVisibility {
  VISIBLE
  HIDDEN
  STARTING_FROM
  ON_REQUEST
}

enum ProductPrimaryAction {
  ADD_TO_CART
  REQUEST_PRICE
  BOOK_APPOINTMENT
  WHATSAPP
  CONTACT_FORM
  NONE
}

enum ProductCategoryStatus {
  ACTIVE
  ARCHIVED
}

// Faz 1B (ADR-067) — Attribute katalog cekirdegi. scope AttributeDefinition'in
// PLATFORM (tum magazalar, storeId null) mi yoksa STORE (tek magaza, storeId zorunlu)
// mu oldugunu belirler. Yetki: PLATFORM yalniz SUPER_ADMIN; STORE ilgili store admin.
enum AttributeScope {
  PLATFORM
  STORE
}

// Faz 1B (ADR-067) — Desteklenen attribute veri tipleri. dataType kullanim
// basladiktan sonra IMMUTABLE (service guard); value tablolari bu fazda YOK.
enum AttributeDataType {
  TEXT
  TEXTAREA
  RICH_TEXT
  INTEGER
  DECIMAL
  BOOLEAN
  DATE
  URL
  SELECT
  MULTI_SELECT
  COLOR
  IMAGE
  FILE
}

// Faz 1B (ADR-067) — AttributeDefinition + AttributeOption yasam durumu. ARCHIVED
// tanim/secenek yeni CategoryAttribute baglamasinda REDDEDILIR (ProductCategoryStatus
// deseniyle ayni). Silme YOK; arsivleme ile emekli edilir.
enum AttributeStatus {
  ACTIVE
  ARCHIVED
}

// ADR-065 — Site-geneli gorsel yonetimi. MediaAsset'in hangi baglamda uretildigini
// tutar; storageKey path segmenti de bundan turer (products/categories/hero/branding).
enum MediaContext {
  PRODUCT
  CATEGORY
  HERO
  BRANDING
}

// ADR-065 — Yayin durumu (hero slide gibi vitrin icerikleri icin). DRAFT admin'de
// gorunur ama vitrine cikmaz; PUBLISHED vitrinde yayinlanir.
enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum ProductVariantStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Faz 2C-3 (ADR-072) — Bir ProductVariant'in KAYNAGI. MANUAL: kullanici/legacy elle olusturdu
// (mevcut TUM varyantlar migration default'u ile MANUAL). ATTRIBUTE_COMBINATION: Combination Engine
// recetesinden uretildi. Sistem YALNIZ ATTRIBUTE_COMBINATION varyantlari archive/restore eder;
// MANUAL varyantlara DOKUNMAZ (izolasyon). String magic value DEGIL — guclu tip.
enum VariantGenerationSource {
  MANUAL
  ATTRIBUTE_COMBINATION
}

enum InventoryMovementType {
  ADJUSTMENT
  SALE_RESERVATION
  SALE_RELEASE
  RETURN
  IMPORT
}

enum CustomerStatus {
  ACTIVE
  PASSIVE
  BLOCKED
  ARCHIVED
}

// Storefront uyelik profili icin cinsiyet (F3B.3). Zorunlu degil (nullable).
enum CustomerGender {
  FEMALE
  MALE
  OTHER
}

// Musteri OTP dogrulama amaci (F3B.3). Kayit/giris/iletisim dogrulama.
enum CustomerOtpPurpose {
  REGISTER
  LOGIN
  VERIFY_CONTACT
}

// OTP teslimat kanali (F3B.3). Gercek saglayici yok; dev/mock provider-ready.
enum CustomerOtpChannel {
  EMAIL
  SMS
}

// Admin tetikli credential token amaci (TODO-087, ADR-035). ADMIN_ACTIVATION:
// credential'i olmayan musteriye uyelik hesabi actirir + ACTIVE yapar.
// ADMIN_PASSWORD_RESET: mevcut credential'in parolasini yeniler.
enum CustomerCredentialTokenPurpose {
  ADMIN_ACTIVATION
  ADMIN_PASSWORD_RESET
}

enum AddressType {
  SHIPPING
  BILLING
}

enum BillingType {
  INDIVIDUAL
  CORPORATE
}

enum OrderStatus {
  DRAFT
  PLACED
  CONFIRMED
  CANCELLED
  FULFILLED
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
  CANCELLED
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

// TODO-152 (ADR-076) — Inventory Engine · depo durumu. INACTIVE depo yeni stok işlemine kapalı.
enum WarehouseStatus {
  ACTIVE
  INACTIVE
}

// TODO-152 (ADR-076) — Inventory Engine · kullanıcı-düzenlenebilir bakiye alanı (audit/rule hedefi).
// `reserved` SİSTEM-kontrollüdür (kullanıcı düzenlemez) → bu enum'da bilinçli olarak YOKTUR.
enum InventoryAdjustmentField {
  ON_HAND
  INCOMING
  SAFETY_STOCK
  REORDER_POINT
}

// TODO-152 (ADR-076) — Inventory apply kaynağı. Bu fazda yalnız MANUAL_EDIT/BULK_OPERATION UI'dan
// üretilir; ORDER_* / IMPORT / SYSTEM ileride rezerve (enum'da tutulur, kullanıcı UI'ına sızmaz).
enum InventoryAdjustmentSource {
  MANUAL_EDIT
  BULK_OPERATION
  ORDER_RESERVATION
  ORDER_RELEASE
  ORDER_COMMIT
  IMPORT
  SYSTEM
}

enum PaymentProviderType {
  MOCK
  IYZICO
  STRIPE
  PAYTR
  GENERIC_REDIRECT
}

enum PaymentProviderMode {
  TEST
  LIVE
}

enum PaymentMethodType {
  CARD
  BANK_TRANSFER
  CASH_ON_DELIVERY
  PAYMENT_LINK
}

enum PaymentProviderStatus {
  ENABLED
  DISABLED
}

enum ThreeDsMode {
  DISABLED
  OPTIONAL
  REQUIRED
}

enum PaymentAttemptStatus {
  CREATED
  PENDING
  REQUIRES_ACTION
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProviderEventType {
  PAYMENT_CREATED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PAYMENT_CANCELLED
  PAYMENT_REFUNDED
  WEBHOOK_RECEIVED
  CONNECTION_TEST
  STATUS_CHANGED
}

// ─────────────────────── F3C.1 Shipping provider foundation ───────────────────────
// Magaza bazli opsiyonel kargo saglayici altyapisi. UI/domain dilinde "DHL eCommerce"
// kullanilir; "MNG" yalnizca teknik endpoint/dokuman referansinda gecer (api.mngkargo.com.tr).
enum ShippingProviderType {
  MOCK
  GELIVER
  DHL_ECOMMERCE
}

enum ShippingProviderMode {
  TEST
  LIVE
}

enum ShippingProviderStatus {
  ENABLED
  DISABLED
}

// DHL/MNG portalinda her API urunu icin ayri "Anahtar" + "Guvenlik dizgisi" uretilebilir;
// bu yuzden config tek apiKey/secret varsaymaz, credential type bazli saklar.
enum ShippingCredentialType {
  DEFAULT
  IDENTITY
  PLUS_COMMAND
  STANDARD_COMMAND
  STANDARD_QUERY
  BARCODE_COMMAND
  CBS_INFO
  BULK_QUERY
  FINANCE_QUERY
}

// F3C.3 — DHL yanit netlestirmesi (ADR-045): DHL statusCode 0-7 normalize durumlari.
// createOrder = "DHL gonderi kaydi" (fiziksel teslim DEGIL). LABEL_PENDING = createbarcode
// HTTP 200 ama bos payload (shipmentId/barcodes yok). OUT_FOR_DELIVERY/DELIVERY_FAILED
// DHL kod 4/6. 6 (teslim edilemedi) FINAL DEGIL; takip gerektirir → ACTIVE sayilir.
enum ShipmentStatus {
  DRAFT
  ORDER_CREATED
  LABEL_PENDING
  LABEL_CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RETURNED
  CANCELLED
  FAILED
}

// TODO-104 — imzasi gecerli webhook teslimatinin isleme sonucu.
// ACCEPTED = shipment bulundu, durum/event islendi.
// IGNORED_UNKNOWN_SHIPMENT = imza gecerli ama eslesen gonderi yok (audit kaydi kalir).
// IGNORED_UNSUPPORTED = imza gecerli ama payload normalize sozlesmeye uymuyor.
enum ShipmentWebhookOutcome {
  ACCEPTED
  IGNORED_UNKNOWN_SHIPMENT
  IGNORED_UNSUPPORTED
}

enum ShipmentEventType {
  CREATED
  ORDER_CREATED
  BARCODE_CREATED
  BARCODE_PENDING
  BARCODE_FAILED
  STATUS_CHANGED
  TRACKING_UPDATED
  // F3C.5 (TODO-121) — admin manuel takip no girisi (provider-agnostic aksiyon).
  MANUAL_TRACKING
  // TODO-124 — admin varis il/ilce eslemesi duzeltmesi (CBS kodlari snapshot'a yazildi).
  DESTINATION_REPAIRED
  CANCELLED
  WEBHOOK_RECEIVED
}

// ─────────────────────── F3C.2 Shipping price engine (store tarife) ───────────────────────
// Kargo ucreti SAGLAYICI quote'u DEGILDIR; magaza/admin tarafindan girilen tarife
// uzerinden hesaplanir (bkz. ADR-036). provider yalnizca operasyon sağlayıcısıyla
// gevsek iliskilendirme icindir; fiyat provider'dan canli cekilmez.
enum ShippingRatePlanStatus {
  ACTIVE
  PASSIVE
}

enum ShippingRatePricingMode {
  FIXED
  FREE_THRESHOLD
  DESI_TABLE
  WEIGHT_TABLE
  DESI_AND_REGION_TABLE
}

enum ShippingRateSource {
  STORE_FIXED_RULE
  STORE_SHIPPING_TARIFF
  MOCK
}

// F3C.2 revizyon — Generic tariff engine ucret tipi (ADR-044). Provider'a ozel
// fiyat kodu YOKTUR; DHL/Aras/Yurtici fiyat listeleri bu generic kurallara
// maplenir. PER_ADDITIONAL_KG_OR_DESI = DHL/Aras "30+/31+" satirlarini temsil eder
// (base + esik ustu birim ucret); satirin toplam mi ek-birim mi oldugu provider
// teyidine kadar ek-birim varsayilir (docs TODO).
enum ShippingChargeType {
  FLAT
  PER_KG
  PER_DESI
  PER_KG_OR_DESI
  PER_ADDITIONAL_KG_OR_DESI
}

// ─────────────────────── F4A Campaigns & Coupons MVP ───────────────────────
// Indirim KAYNAK DOGRUSU sunucu tarafi motorudur (ADR-058); istemciden gelen
// indirim tutari ASLA kabul edilmez. Kampanya/kupon store-scoped'tur.
enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// MVP: COUPON_CODE / AUTOMATIC_CART / PRODUCT_DISCOUNT / CATEGORY_DISCOUNT.
// BUY_X_GET_Y / FREE_SHIPPING / MEMBERSHIP_ONLY gelecek fazlar icin yalnizca
// enum rezervi; motor bu tipleri MVP'de UYGULAMAZ (bilinmeyen tip = atlanir).
enum CampaignType {
  COUPON_CODE
  AUTOMATIC_CART
  PRODUCT_DISCOUNT
  CATEGORY_DISCOUNT
  BUY_X_GET_Y
  FREE_SHIPPING
  MEMBERSHIP_ONLY
}

enum CampaignDiscountType {
  PERCENT
  FIXED_AMOUNT
}

// F4A.4 — Kupon karti SUNUM alanlari (ADR-061). Bu enumlar YALNIZCA gorunumdur;
// indirim motorunu ETKILEMEZ. FOLLOW/store-follow/seller-follow gibi takip
// tabanli hicbir deger BILINCLI olarak yoktur (bu urun marketplace degildir).
enum CampaignBadgeVariant {
  DEFAULT
  SUPER
  LIMITED_TIME
  PERSONAL
  WEEKEND
  NEW_CUSTOMER
}

enum CampaignCardStyle {
  STANDARD
  FEATURED
  PERSONAL
}

// F4A.4 — Erisim/edinme modeli (ADR-061). isPublic bu secimden TURETILIR ve
// public projeksiyon icin AUTHORITATIVE gate olarak kalir:
//   AUTO_VISIBLE / PUBLIC_CLAIMABLE => isPublic=true
//   CODE_CLAIMED  / ADMIN_ASSIGNED  => isPublic=false
// Reserved (FIRST_ORDER/RETURNING/EMAIL_LIST) motor tarafindan enforce
// edilemedigi icin enum'a EKLENMEZ.
enum CampaignAccessModel {
  AUTO_VISIBLE
  PUBLIC_CLAIMABLE
  CODE_CLAIMED
  ADMIN_ASSIGNED
}

enum CouponStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// F4A.3 — Musteri kupon cuzdani (wallet) durum/kaynak (ADR-060).
enum CustomerCouponStatus {
  AVAILABLE
  APPLIED
  USED
  REVOKED
}

enum CustomerCouponSource {
  ADMIN_ASSIGNED
  PUBLIC_CLAIMED
  CODE_CLAIMED
}

model PlatformUser {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String
  role         PlatformUserRole @default(SUPPORT_ADMIN)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  storeUsers StoreUser[]
  auditLogs  AuditLog[]
  sessions   PlatformSession[]
}

model PlatformSession {
  id             String    @id @default(cuid())
  platformUserId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@index([expiresAt])
}

model Store {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  status    StoreStatus @default(DRAFT)
  metadata  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users                            StoreUser[]
  domains                          StoreDomain[]
  subscriptions                    Subscription[]
  products                         Product[]
  variants                         ProductVariant[]
  categories                       ProductCategory[]
  inventory                        InventoryItem[]
  movements                        InventoryMovement[]
  customers                        Customer[]
  customerAddresses                CustomerAddress[]
  customerCredentials              CustomerCredential[]
  customerCredentialTokens         CustomerCredentialToken[]
  customerSessions                 CustomerSession[]
  customerOtpVerifications         CustomerOtpVerification[]
  customerIbans                    CustomerIban[]
  customerCommunicationPreferences CustomerCommunicationPreference[]
  orders                           Order[]
  orderLines                       OrderLine[]
  orderAddresses                   OrderAddress[]
  orderEvents                      OrderEvent[]
  orderCounters                    OrderNumberCounter[]
  reservations                     InventoryReservation[]
  auditLogs                        AuditLog[]
  eventLogs                        EventLog[]
  queueJobLogs                     QueueJobLog[]
  paymentProviderConfigs           PaymentProviderConfig[]
  paymentAttempts                  PaymentAttempt[]
  paymentProviderEvents            PaymentProviderEvent[]
  shippingProviderConfigs          ShippingProviderConfig[]
  shipments                        Shipment[]
  shipmentEvents                   ShipmentEvent[]
  shipmentQuotes                   ShipmentQuote[]
  shipmentWebhookInbox             ShipmentWebhookInbox[]
  shippingRatePlans                ShippingRatePlan[]
  shippingRateRules                ShippingRateRule[]
  campaigns                        Campaign[]
  coupons                          Coupon[]
  campaignRedemptions              CampaignRedemption[]
  orderDiscounts                   OrderDiscount[]
  customerCoupons                  CustomerCoupon[]
  mediaAssets                      MediaAsset[]
  heroSlides                       HeroSlide[]
  settings                         StoreSettings?
  // Faz 1B (ADR-067) — attribute katalog cekirdegi (STORE-scoped kayitlar). PLATFORM
  // AttributeDefinition/AttributeOption storeId null tutar → bu iliskilere dahil DEGIL.
  attributeDefinitions             AttributeDefinition[]
  attributeGroups                  AttributeGroup[]
  attributeOptions                 AttributeOption[]
  categoryAttributes               CategoryAttribute[]
  // Faz 2A (ADR-068) — urun/varyant attribute DEGER tablolari (STORE-scoped, tenant sutunu).
  productAttributeValues           ProductAttributeValue[]
  variantAttributeValues           VariantAttributeValue[]
  productAttributeValueOptions     ProductAttributeValueOption[]
  // Faz 2C-1 (ADR-070) — varyant motoru temeli: urun-seviyesi variant-defining eksen secimi.
  productVariantAttributes         ProductVariantAttribute[]
  productVariantOptionSelections   ProductVariantOptionSelection[]
  // Faz 2C-3 (ADR-072) — uretilmis varyantin cozulmus eksen->option secimleri (tenant sutunu).
  productVariantOptionValues       ProductVariantOptionValue[]
  // TODO-150 (ADR-073) — Identity Management Engine bulk-apply audit'i (tenant sutunu).
  variantIdentityChanges           VariantIdentityChange[]
  // TODO-151 (ADR-074) — Commercial Engine bulk-apply audit'i (tenant sutunu).
  variantCommercialChanges         VariantCommercialChange[]
  // TODO-152 (ADR-076) — Inventory Engine: depo + warehouse-aware bakiye + append-only düzeltme defteri.
  warehouses                       Warehouse[]
  inventoryBalances                InventoryBalance[]
  inventoryAdjustments             InventoryAdjustment[]
  // Faz 2C-8A (ADR-079) — Search read-model (turetilmis; source-of-truth DEGIL). Cascade → magaza
  // silinince arama dokumanlari/facet satirlari otomatik temizlenir.
  searchDocuments                  ProductSearchDocument[]
  searchFacetValues                ProductFacetValue[]
}

model StoreUser {
  id         String        @id @default(cuid())
  storeId    String
  userId     String
  role       StoreUserRole @default(VIEWER)
  invitedAt  DateTime?
  acceptedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
}

model StoreDomain {
  id        String       @id @default(cuid())
  storeId   String
  domain    String       @unique
  type      DomainType   @default(SYSTEM_SUBDOMAIN)
  status    DomainStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Plan {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  storeId   String
  planId    String
  status    SubscriptionStatus @default(TRIALING)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  metadata  Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  plan  Plan  @relation(fields: [planId], references: [id])

  @@index([storeId])
  @@index([planId])
}

model AuditLog {
  id             String      @id @default(cuid())
  storeId        String?
  platformUserId String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  store        Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([platformUserId])
}

model EventLog {
  id        String    @id @default(cuid())
  storeId   String?
  type      EventType
  payload   Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([type])
}

model QueueJobLog {
  id        String         @id @default(cuid())
  storeId   String?
  jobName   String
  queueName String
  status    QueueJobStatus @default(PENDING)
  attempts  Int            @default(0)
  payload   Json?
  error     Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([queueName, jobName])
  @@index([status])
}

model Product {
  id                       String                 @id @default(cuid())
  storeId                  String
  title                    String
  slug                     String
  description              String?
  status                   ProductStatus          @default(DRAFT)
  type                     ProductType            @default(PHYSICAL)
  vendor                   String?
  brand                    String?
  seoTitle                 String?
  seoDescription           String?
  salesMode                ProductSalesMode       @default(ONLINE)
  priceVisibility          ProductPriceVisibility @default(VISIBLE)
  primaryAction            ProductPrimaryAction   @default(ADD_TO_CART)
  inquiryEnabled           Boolean                @default(false)
  appointmentRequired      Boolean                @default(false)
  whatsappEnabled          Boolean                @default(false)
  purchasable              Boolean                @default(true)
  minOrderQuantity         Int                    @default(1)
  maxOrderQuantity         Int?
  callToActionLabel        String?
  whatsappMessageTemplate  String?
  inquiryFormTitle         String?
  appointmentNote          String?
  // F3C.2 — Kargo olcumu (desi/agirlik). Varyant uzerindeki ayni alanlar onceliklidir;
  // burasi urun-seviyesi fallback. DESI_TABLE/WEIGHT_TABLE tarifelerinde eksikse
  // hesaplama MISSING_SHIPPING_DIMENSIONS doner (admin UI TODO-110).
  shippingWeightKg         Decimal?               @db.Decimal(10, 3)
  shippingDesi             Decimal?               @db.Decimal(10, 2)
  // Faz 1A (ADR-067) — Urunun TEK ana kategorisi. Ileriki dinamik attribute
  // semasinin, breadcrumb'in ve kanonik kategori URL'inin KAYNAGIDIR. M:N
  // `assignments` (ikincil siniflandirma/merchandising) KORUNUR; ana kategori
  // mutlaka assignments'tan biri olmalidir (service transaction guard — DB tek
  // basina garanti edemez). Nullable: legacy/kategorisiz urun null kalir; ilk
  // migration'da NOT NULL YOK. onDelete: Restrict → ana kategori fiziksel silinemez.
  primaryCategoryId        String?
  // Faz 2C-7 (ADR-078) — Variant Media Engine. Bu urunun gorsellerini gruplayan TEK
  // media-tanimlayici eksen (genelde Renk). null = klasik urun galerisi (backward compat:
  // tum gorseller etiketsiz tek grup = bugunku davranis). Yalniz SELECT/COLOR variant-defining
  // eksen secilebilir (service guard). onDelete: SetNull → eksen tanimini silmek galeriyi
  // klasik moda dusurur (gorsel kaybi YOK; etiketler ProductImage'da Restrict ile korunur).
  mediaDefiningAttributeId String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  store                  Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  primaryCategory        ProductCategory?            @relation("ProductPrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: Restrict)
  mediaDefiningAttribute AttributeDefinition?        @relation("ProductMediaAxis", fields: [mediaDefiningAttributeId], references: [id], onDelete: SetNull)
  variants               ProductVariant[]
  assignments            ProductCategoryAssignment[]
  orderLines             OrderLine[]
  campaignProducts       CampaignProduct[]
  images                 ProductImage[]
  // Faz 2A (ADR-068) — urun-seviyesi (non-variantDefining) attribute degerleri.
  attributeValues        ProductAttributeValue[]
  // Faz 2C-1 (ADR-070) — bu urun icin secilen variant-defining eksenler (henuz KOMBINASYON DEGIL).
  variantAttributes      ProductVariantAttribute[]
  // TODO-150 (ADR-073) — bu urunun varyantlarina uygulanan Identity Engine bulk-apply audit satirlari.
  identityChanges        VariantIdentityChange[]
  // TODO-151 (ADR-074) — bu urunun varyantlarina uygulanan Commercial Engine bulk-apply audit satirlari.
  commercialChanges      VariantCommercialChange[]
  // TODO-152 (ADR-076) — bu urunun varyantlarina uygulanan Inventory Engine duzeltme defteri satirlari.
  inventoryAdjustments   InventoryAdjustment[]
  // Faz 2C-8A (ADR-079) — Search read-model (turetilmis). Cascade → urun silinince dokuman + facet
  // satirlari otomatik temizlenir (worker remove-job'a ek DB-seviyesi guvence; orphan olmaz).
  searchDocument         ProductSearchDocument?
  searchFacetValues      ProductFacetValue[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([status])
  @@index([salesMode])
  @@index([purchasable])
  // Faz 1A (ADR-067) — store-scoped ana-kategori sorgulari + FK restrict tarama.
  @@index([storeId, primaryCategoryId])
}

model ProductVariant {
  id               String                  @id @default(cuid())
  productId        String
  storeId          String
  title            String
  sku              String
  barcode          String?
  priceMinor       Int
  compareAtMinor   Int?
  // F4B — Maliyet (minor). Satis fiyati (priceMinor) DEGISMEZ; checkout bunu tahsil eder.
  // costMinor yalnizca ic marj/kar hesabi icindir, ASLA public API'ye sizmaz.
  // Kural: costMinor <= (compareAtMinor ?? priceMinor) (liste/showroom tavani).
  costMinor        Int?
  // F4C (ADR-063) — KDV alanlari. priceMinor KDV DAHIL brut satis fiyati olarak
  // KALIR (vitrin/sepet/checkout sifir-regresyon); admin artik KDV HARIC net
  // fiyati girer, sunucu vat = round(net*bps/10000), brut = net+vat hesaplar ve
  // priceMinor'a yazar. Backfill: net = round(brut*10000/(10000+bps)) — mevcut
  // brut GORUNEN fiyatlar birebir korunur. vatRateBps: 2000=%20, 1000=%10,
  // 100=%1, 0=%0.
  netPriceMinor    Int?
  vatRateBps       Int                     @default(2000)
  vatAmountMinor   Int?
  currency         String
  status           ProductVariantStatus    @default(ACTIVE)
  optionValues     Json?
  // Faz 2C-3 (ADR-072) — Varyant kaynagi + kalici kanonik kombinasyon kimligi + soft-archive damgasi.
  // generationSource: MANUAL (default; mevcut/legacy varyantlar) veya ATTRIBUTE_COMBINATION (uretilmis).
  // combinationKey: yalniz uretilmis varyantta dolu (v1|attrId:optId|...); manuel varyantta null.
  //   @@unique([productId, combinationKey]) — Postgres NULL-distinct: coklu manuel null cakismaz,
  //   uretilmis non-null key ayni urun altinda tektir (concurrency insert-conflict temeli).
  // archivedAt: recetede olmayan uretilmis varyant arsivlendiginde (status=ARCHIVED) set edilir; audit.
  generationSource VariantGenerationSource @default(MANUAL)
  combinationKey   String?
  archivedAt       DateTime?
  // TODO-150 (ADR-073) — Identity Management Engine. titleIsCustom: baslik motor-yonetimli mi (false;
  // Identity Engine yeniden uretebilir) yoksa kullanici-yazimi/korumali mi (true). Varyant PATCH
  // `title` verilince true isaretler; Identity title-apply true'yu (regenerateCustomTitles olmadan)
  // ATLAR → "Title override edilirse yeniden generate edilmemeli". Default false: additive/geriye-uyumlu
  // (mevcut varyantlarin gorunen basligi degismez; yalnizca acik bir apply preview-gate'li yazar).
  titleIsCustom    Boolean                 @default(false)
  // F3C.2 — Kargo olcumu (desi/agirlik); urun-seviyesi degerleri override eder.
  shippingWeightKg Decimal?                @db.Decimal(10, 3)
  shippingDesi     Decimal?                @db.Decimal(10, 2)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  product               Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  store                 Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventory             InventoryItem?
  movements             InventoryMovement[]
  orderLines            OrderLine[]
  reservations          InventoryReservation[]
  // Faz 2A (ADR-068) — variantDefining attribute degerleri (yalniz valueText/optionId).
  attributeValues       VariantAttributeValue[]
  // Faz 2C-3 (ADR-072) — uretilmis varyantin cozulmus eksen->option secimi (normalize; combinationKey ile
  // tutarli). Manuel varyantta bos kalir (attributeValues 2A ile karistirilmaz — ayri yazma otoritesi).
  optionValueSelections ProductVariantOptionValue[]
  // TODO-150 (ADR-073) — Identity Management Engine bulk-apply audit'i (append-only; undo metadata).
  identityChanges       VariantIdentityChange[]
  // TODO-151 (ADR-074) — Commercial Engine bulk-apply audit'i (append-only; undo metadata).
  commercialChanges     VariantCommercialChange[]
  // TODO-152 (ADR-076) — Inventory Engine: warehouse-aware bakiye + append-only duzeltme defteri.
  inventoryBalances     InventoryBalance[]
  inventoryAdjustments  InventoryAdjustment[]

  @@unique([storeId, sku])
  // Faz 2C-3 (ADR-072) — ayni urunde ayni kombinasyon tek varyant (NULL-distinct: manuel null serbest).
  @@unique([productId, combinationKey])
  @@index([productId])
  @@index([storeId])
  @@index([status])
}

// F4B — Kampanya-disi fiyat/liste/maliyet degisikligi audit'i (append-only).
// EU Omnibus "son 30 gunun en dusuk fiyati" gosteriminin veri temeli.
// changedByPlatformUserId FK degil, dogrudan scalar: kullanici silinse bile
// tarihsel kayit korunur. storeId/variantId indexli sorgu icin tutulur.
enum PriceChangeSource {
  ADMIN_EDIT
  IMPORT
  API
}

model ProductPriceChange {
  id                      String            @id @default(cuid())
  storeId                 String
  productId               String
  variantId               String
  changedByPlatformUserId String?
  currency                String
  oldPriceMinor           Int?
  newPriceMinor           Int?
  oldCompareAtMinor       Int?
  newCompareAtMinor       Int?
  oldCostMinor            Int?
  newCostMinor            Int?
  source                  PriceChangeSource @default(ADMIN_EDIT)
  reason                  String?
  createdAt               DateTime          @default(now())

  @@index([storeId, variantId, createdAt])
  @@index([storeId, createdAt])
}

model ProductCategory {
  id        String                @id @default(cuid())
  storeId   String
  name      String
  slug      String
  parentId  String?
  sortOrder Int                   @default(0)
  status    ProductCategoryStatus @default(ACTIVE)
  imageId   String? // ADR-065 — opsiyonel tekil kategori gorseli
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  store              Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent             ProductCategory?            @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children           ProductCategory[]           @relation("ProductCategoryTree")
  assignments        ProductCategoryAssignment[]
  // Faz 1A (ADR-067) — bu kategoriyi ANA kategori olarak tutan urunler (Restrict).
  primaryProducts    Product[]                   @relation("ProductPrimaryCategory")
  campaignCategories CampaignCategory[]
  image              MediaAsset?                 @relation("CategoryImage", fields: [imageId], references: [id], onDelete: SetNull)
  // Faz 1B (ADR-067) — bu kategoriye bagli attribute davranislari (tek sahip).
  attributeLinks     CategoryAttribute[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([parentId])
  @@index([status])
}

model ProductCategoryAssignment {
  productId  String
  categoryId String
  storeId    String
  createdAt  DateTime @default(now())

  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@unique([storeId, productId, categoryId])
  @@index([storeId])
  @@index([categoryId])
}

model InventoryItem {
  id                String   @id @default(cuid())
  storeId           String
  variantId         String   @unique
  quantityOnHand    Int      @default(0)
  quantityReserved  Int      @default(0)
  lowStockThreshold Int?
  updatedAt         DateTime @updatedAt

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([variantId])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  storeId       String
  variantId     String
  type          InventoryMovementType @default(ADJUSTMENT)
  quantityDelta Int
  reason        String?
  referenceType String?
  referenceId   String?
  actorUserId   String?
  createdAt     DateTime              @default(now())

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([variantId])
  @@index([type])
}

// TODO-152 (ADR-076) — Inventory Engine · Store-scoped depo. Bu faz store başına bir DEFAULT depo
// (migration backfill) kurar; ek depo CRUD UI TD-046. `isDefault` store başına TEK olmalıdır
// (migration'da partial unique index). Silme yerine INACTIVE tercih edilir (yeni stok işlemine kapalı).
model Warehouse {
  id        String          @id @default(cuid())
  storeId   String
  code      String
  name      String
  status    WarehouseStatus @default(ACTIVE)
  isDefault Boolean         @default(false)
  priority  Int             @default(0)
  // Opsiyonel adres (bilgi amaçlı; fulfillment/kargo yetkinliği bu fazda YOK).
  city      String?
  district  String?
  line1     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  store       Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  balances    InventoryBalance[]
  adjustments InventoryAdjustment[]

  @@unique([storeId, code])
  @@index([storeId])
  @@index([storeId, status])
}

// TODO-152 (ADR-076) — Variant × Warehouse stok özeti. onHand/reserved DEFAULT depo için
// InventoryItem ile senkron tutulur (InventoryItem otorite; checkout/storefront sıfır regresyon);
// safetyStock/incoming/reorderPoint bu tabloda otoriterdir. `available` TÜRETİLİR (kolon YOK):
// available = onHand − reserved − safetyStock. Unique = varyant × depo tek bakiye.
model InventoryBalance {
  id           String   @id @default(cuid())
  storeId      String
  warehouseId  String
  variantId    String
  onHand       Int      @default(0)
  reserved     Int      @default(0)
  incoming     Int      @default(0)
  safetyStock  Int      @default(0)
  reorderPoint Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, variantId])
  @@index([storeId])
  @@index([variantId])
  @@index([storeId, warehouseId])
}

// TODO-152 (ADR-076) — Append-only stok düzeltme defteri (audit/ledger). Her DEĞİŞEN alan için bir
// satır; tek apply = tek batchId (undo/tanı temeli). oldValue/newValue/delta üçü de tutulur (Set
// Absolute + Adjust Delta ayrımı görünür). `reserved` kullanıcı-düzenlenmez → yalnız sistem
// kaynakları (ORDER_*) reserved yazabilir; bu fazda üretilmez. changedByPlatformUserId FK DEĞİL,
// scalar: kullanıcı silinse bile tarihsel kayıt korunur (ProductPriceChange deseni).
model InventoryAdjustment {
  id                      String                    @id @default(cuid())
  storeId                 String
  warehouseId             String
  productId               String
  variantId               String
  field                   InventoryAdjustmentField
  oldValue                Int
  newValue                Int
  delta                   Int
  reason                  String?
  source                  InventoryAdjustmentSource
  batchId                 String
  changedByPlatformUserId String?
  createdAt               DateTime                  @default(now())

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([warehouseId])
  @@index([productId])
  @@index([variantId])
  @@index([batchId])
  @@index([storeId, variantId, createdAt])
}

// Storefront musteri kimligi (F3B.3). Tek kavram: hem store-admin CRM kaydi hem
// storefront uyelik hesabi ayni Customer satiridir (ADR-032). email/phone store
// scope'unda unique ve NULL'lanabilir (GSM-only ya da email-only kayit). Auth/
// profil alanlari burada; sifre/otp/session/iban/iletisim tercihi alt tablolarda.
model Customer {
  id              String          @id @default(cuid())
  storeId         String
  email           String?
  firstName       String?
  lastName        String?
  phone           String?
  birthDate       DateTime?
  gender          CustomerGender?
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  status          CustomerStatus  @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  store                   Store                            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  addresses               CustomerAddress[]
  orders                  Order[]
  credential              CustomerCredential?
  credentialTokens        CustomerCredentialToken[]
  sessions                CustomerSession[]
  otpVerifications        CustomerOtpVerification[]
  ibans                   CustomerIban[]
  communicationPreference CustomerCommunicationPreference?
  campaignRedemptions     CampaignRedemption[]
  customerCoupons         CustomerCoupon[]

  @@unique([storeId, email])
  @@unique([storeId, phone])
  @@index([storeId])
  @@index([status])
}

// Sifre kimligi (F3B.3). Plain sifre ASLA saklanmaz; scrypt hash @commerce-os/auth.
model CustomerCredential {
  id                String   @id @default(cuid())
  storeId           String
  customerId        String   @unique
  passwordHash      String
  passwordChangedAt DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// Admin tetikli aktivasyon/parola-sifirlama token'i (TODO-087, ADR-035). Plain
// token ASLA saklanmaz/loglanmaz; yalnizca sha256 tokenHash (SESSION_SECRET ile).
// Raw token yalniz uretim response'unda tek seferlik doner. createdByUserId:
// token'i ureten platform-admin. Tek seferlik: consumedAt ile tuketilir.
model CustomerCredentialToken {
  id              String                         @id @default(cuid())
  storeId         String
  customerId      String
  purpose         CustomerCredentialTokenPurpose
  tokenHash       String                         @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  createdByUserId String
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([expiresAt])
}

// Musteri oturumu (F3B.3). PlatformSession deseni: raw token DB'de tutulmaz,
// yalnizca sha256 tokenHash. Storefront httpOnly cookie -> gateway server-to-server.
model CustomerSession {
  id         String    @id @default(cuid())
  storeId    String
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([expiresAt])
}

// OTP dogrulama (F3B.3). Plain kod ASLA saklanmaz/loglanmaz; yalnizca codeHash.
// destination, koda ait hedef (kullanicinin kendi email/telefonu) eslestirme icin.
model CustomerOtpVerification {
  id           String             @id @default(cuid())
  storeId      String
  customerId   String
  purpose      CustomerOtpPurpose
  channel      CustomerOtpChannel
  destination  String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([expiresAt])
}

// IBAN bilgisi (F3B.3). Iade/iptal sureci icin saklanir. DB'de tam IBAN tutulur;
// API response'larinda MASKELI doner. Event/log metadata'ya IBAN yazilmaz.
model CustomerIban {
  id                String    @id @default(cuid())
  storeId           String
  customerId        String
  accountHolderName String
  iban              String
  isDefault         Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
}

// Iletisim tercihleri (F3B.3, KVKK izin modeli). Musteri basina tek satir.
// smsEnabled = "Anlik / Kisa Mesaj"; phoneEnabled = telefon ile arama izni.
model CustomerCommunicationPreference {
  id           String   @id @default(cuid())
  storeId      String
  customerId   String   @unique
  smsEnabled   Boolean  @default(false)
  emailEnabled Boolean  @default(true)
  phoneEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// Adres defteri (F3B.3, F3B.2 fatura ile uyumlu). Bir adres hem teslimat hem
// fatura kimligi tasiyabilir. Bireysel: tckn (11 hane); Kurumsal: companyName +
// taxOffice + taxNumber (VKN 10 hane). TCKN/VKN response'ta maskeli; log'a yazilmaz.
// Soft delete: deletedAt set edilir, satir korunur (gecmis siparis butunlugu).
model CustomerAddress {
  id                String       @id @default(cuid())
  storeId           String
  customerId        String
  type              AddressType  @default(SHIPPING)
  addressName       String       @default("")
  fullName          String
  phone             String?
  countryCode       String       @default("TR")
  city              String
  district          String?
  addressLine1      String
  addressLine2      String?
  postalCode        String?
  isDefaultShipping Boolean      @default(false)
  isDefaultBilling  Boolean      @default(false)
  billingType       BillingType?
  tckn              String?
  companyName       String?
  taxOffice         String?
  taxNumber         String?
  deletedAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([type])
}

model OrderNumberCounter {
  id        String   @id @default(cuid())
  storeId   String   @unique
  nextValue Int      @default(1)
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Order {
  id                   String                @id @default(cuid())
  storeId              String
  orderNumber          String
  customerId           String?
  customerEmail        String
  currency             String
  status               OrderStatus           @default(DRAFT)
  paymentStatus        PaymentStatus         @default(UNPAID)
  fulfillmentStatus    FulfillmentStatus     @default(UNFULFILLED)
  subtotalAmount       Int                   @default(0)
  discountAmount       Int                   @default(0)
  shippingAmount       Int                   @default(0)
  // F3C.2 — Kargo ucreti SNAPSHOT'i (siparis aninda magaza tarifesinden hesaplanan
  // tutarin kaynagi ve plan kimligi). Tutar shippingAmount'tadir; bu alanlar
  // izlenebilirlik icindir. Provider canli quote DEGILDIR (bkz. ADR-036).
  shippingCurrency     String?
  shippingSource       ShippingRateSource?
  shippingRatePlanId   String?
  shippingRatePlanName String?
  // TODO-125 (ADR-047) — Checkout'ta SEÇİLEN kargo sağlayıcı/seçenek SNAPSHOT'i.
  // Tarihsel sipariş, config sonradan değişse bile sabit kalsın diye sağlayıcı
  // görünüm bilgisi de yazılır. shippingProvider = taşıyıcı kimliği (enum),
  // shippingProviderName = görünen ad, shippingLogoUrl = public logo (secret DEĞİL),
  // shippingEtaText = tahmini teslim metni. ratePlanName service/method adıdır.
  shippingProvider     ShippingProviderType?
  shippingProviderName String?
  shippingLogoUrl      String?
  shippingEtaText      String?
  taxAmount            Int                   @default(0)
  totalAmount          Int                   @default(0)
  placedAt             DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  // Fatura kimlik bilgileri (F3B.2). Fatura ADRESI OrderAddress(type=BILLING)
  // kaydinda tutulur; burada yalnizca fatura tipi + vergi/kimlik kimlik alanlari
  // bulunur. Bireysel: billingTaxId = T.C. Kimlik No (11 hane). Kurumsal: firma
  // unvani + vergi dairesi + vergi no. PII gereksiz log/event metadata'ya yazilmaz.
  billingType          BillingType?
  billingName          String?
  billingTaxId         String?
  billingCompanyName   String?
  billingTaxOffice     String?
  billingTaxNumber     String?
  billingEmail         String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  store           Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines           OrderLine[]
  addresses       OrderAddress[]
  events          OrderEvent[]
  reservations    InventoryReservation[]
  paymentAttempts PaymentAttempt[]
  paymentEvents   PaymentProviderEvent[]
  shipments       Shipment[]
  shipmentQuotes  ShipmentQuote[]
  // F4A — Siparis indirim snapshot'lari + kampanya kullanim kayitlari.
  discounts       OrderDiscount[]
  redemptions     CampaignRedemption[]
  customerCoupons CustomerCoupon[]

  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([customerId])
  @@index([status])
}

model OrderLine {
  id                   String   @id @default(cuid())
  storeId              String
  orderId              String
  productId            String
  variantId            String
  sku                  String
  title                String
  variantTitle         String
  quantity             Int
  unitPriceAmount      Int
  totalAmount          Int
  currency             String
  // F4C (ADR-063/ADR-064) — Siparis ani KDV/maliyet/liste SNAPSHOT'lari
  // (fatura/yasal belge + kar analizi temeli). unitPriceAmount/totalAmount
  // KDV DAHIL brut olarak KALIR (geri uyum); asagidaki alanlar additive'dir ve
  // ESKI siparislerde NULL kalir (legacy — yeniden HESAPLANMAZ, yaniltici sifir
  // gosterilmez). unitGross/lineGross bilincli acik yazilir (fatura semantigi).
  // unitListPriceMinor = siparis anindaki liste fiyati (compareAt ?? brut satis).
  unitNetPriceMinor    Int?
  unitVatRateBps       Int?
  unitVatAmountMinor   Int?
  unitGrossPriceMinor  Int?
  unitListPriceMinor   Int?
  unitCostMinor        Int?
  lineNetAmountMinor   Int?
  lineVatAmountMinor   Int?
  lineGrossAmountMinor Int?
  lineCostMinor        Int?
  createdAt            DateTime @default(now())

  store        Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant      ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  reservations InventoryReservation[]

  @@index([storeId])
  @@index([orderId])
  @@index([variantId])
}

model OrderAddress {
  id           String      @id @default(cuid())
  storeId      String
  orderId      String
  type         AddressType
  fullName     String
  phone        String?
  countryCode  String
  city         String
  district     String?
  addressLine1 String
  addressLine2 String?
  postalCode   String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([type])
}

model OrderEvent {
  id          String   @id @default(cuid())
  storeId     String
  orderId     String
  type        String
  message     String?
  metadata    Json?
  actorUserId String?
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([type])
}

model InventoryReservation {
  id          String                     @id @default(cuid())
  storeId     String
  orderId     String
  orderLineId String
  variantId   String
  quantity    Int
  status      InventoryReservationStatus @default(ACTIVE)
  expiresAt   DateTime?
  releasedAt  DateTime?
  consumedAt  DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLine OrderLine      @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([storeId])
  @@index([orderId])
  @@index([orderLineId])
  @@index([variantId])
  @@index([status])
}

// F3B.2 Payment Operations Foundation.
// Saglayici credential'lari yalniz ciphertext (apiKeyCipher/secretKeyCipher/
// webhookSecretCipher) olarak saklanir; duz metin DB'ye asla yazilmaz, client'a
// asla maskesiz donmez. Canli odeme bu fazda YOK; provider-ready operasyon katmani.
model PaymentProviderConfig {
  id                  String                @id @default(cuid())
  storeId             String
  provider            PaymentProviderType
  displayName         String
  status              PaymentProviderStatus @default(DISABLED)
  mode                PaymentProviderMode   @default(TEST)
  priority            Int                   @default(100)
  supportedMethods    PaymentMethodType[]
  supportedCurrencies String[]
  minAmount           Int?
  maxAmount           Int?
  threeDsMode         ThreeDsMode           @default(DISABLED)
  installmentEnabled  Boolean               @default(false)
  fallbackEnabled     Boolean               @default(false)
  merchantId          String?
  callbackUrl         String?
  apiKeyCipher        String?
  secretKeyCipher     String?
  webhookSecretCipher String?
  lastTestStatus      String?
  lastTestMessage     String?
  lastTestAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  store    Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  attempts PaymentAttempt[]
  events   PaymentProviderEvent[]

  @@unique([storeId, provider, mode])
  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, priority])
}

model PaymentAttempt {
  id                   String               @id @default(cuid())
  storeId              String
  orderId              String
  providerConfigId     String
  provider             PaymentProviderType
  mode                 PaymentProviderMode
  method               PaymentMethodType
  amount               Int
  currency             String
  status               PaymentAttemptStatus @default(CREATED)
  threeDsApplied       Boolean              @default(false)
  scenario             String?
  // Odeme gozlemlenebilirligi (F3B.2). Full PAN/CVC ASLA saklanmaz; yalniz
  // turetilmis guvenli alanlar: kart markasi + son 4 hane + taksit sayisi.
  installmentCount     Int                  @default(1)
  cardBrand            String?
  cardLast4            String?
  // providerReference = saglayici islem (transaction) referansi.
  providerReference    String?
  failureCode          String?
  failureMessage       String?
  paidAt               DateTime?
  failedAt             DateTime?
  // Kisa omurlu public odeme erisim token'inin hash'i; plain token DB'ye yazilmaz.
  accessTokenHash      String?
  accessTokenExpiresAt DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerConfig PaymentProviderConfig  @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  events         PaymentProviderEvent[]

  @@index([storeId])
  @@index([orderId])
  @@index([providerConfigId])
  @@index([status])
  @@index([accessTokenHash])
}

model PaymentProviderEvent {
  id               String                   @id @default(cuid())
  storeId          String
  providerConfigId String?
  attemptId        String?
  orderId          String?
  provider         PaymentProviderType
  type             PaymentProviderEventType
  // Provider/webhook external event id varsa set edilir; internal eventlerde null.
  eventId          String?
  message          String?
  metadata         Json?
  createdAt        DateTime                 @default(now())

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  providerConfig PaymentProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  attempt        PaymentAttempt?        @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  order          Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([storeId, provider, eventId], map: "payment_provider_event_unique_external_event")
  @@index([storeId])
  @@index([providerConfigId])
  @@index([attemptId])
  @@index([orderId])
  @@index([type])
}

// ─────────────────────── F3C.1 Shipping provider foundation ───────────────────────

model ShippingProviderConfig {
  id                     String                 @id @default(cuid())
  storeId                String
  provider               ShippingProviderType
  mode                   ShippingProviderMode   @default(TEST)
  status                 ShippingProviderStatus @default(DISABLED)
  displayName            String
  // F3C.5 (TODO-121) — Provider logo (public, secret DEGIL). UI'da liste/detay/ozet
  // kartinda gosterilir; bozuk/eksik URL'de provider initials fallback uygulanir.
  // logoStorageKey ileride object-store entegrasyonu icin TODO (su an dis URL).
  logoUrl                String?
  logoAlt                String?
  // Destructive/costly operasyon guard'lari. Hepsi varsayilan KAPALI; canli
  // createOrder/createbarcode/acceptOffer ancak ilgili env flag + bu alan + request
  // explicitConfirm uclusu saglaninca calisir (aksi halde 409).
  // Plus Command / createRecipient guard'i (paketleme öncesi varış şube tespiti).
  allowRecipientCreate   Boolean                @default(false)
  allowOrderCreate       Boolean                @default(false)
  allowBarcodeCreate     Boolean                @default(false)
  allowLabelPurchase     Boolean                @default(false)
  // TODO-094B — son test "durumu". connectionStatus degerleri: OK/FAILED/HTTP_DISABLED/
  // SKIPPED (null => UNTESTED). HTTP transport kapaliyken test ASLA OK yazmaz.
  lastTestedAt           DateTime?
  lastTestStatus         String?
  lastErrorCode          String?
  // Son GERCEK provider HTTP testinin meta'si. Transport kapaliyken httpStatus null kalir.
  lastProviderHttpStatus Int?
  lastProviderTestType   String?
  // TODO-104 — provider webhook guvenligi. webhookToken URL yol parcasidir (config
  // cozumleme kimligi; TEK BASINA YETKI VERMEZ — HMAC imza her istekte zorunlu).
  // Secret AES-256-GCM ciphertext olarak saklanir (SHIPPING_ENCRYPTION_KEY);
  // response'a ASLA donmez, yalniz rotate aninda BIR KEZ plain doner (ADR-035 deseni).
  webhookToken           String?                @unique
  webhookSecretCipher    String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  store        Store                        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  credentials  ShippingProviderCredential[]
  shipments    Shipment[]
  quotes       ShipmentQuote[]
  webhookInbox ShipmentWebhookInbox[]

  @@unique([storeId, provider, mode])
  @@index([storeId])
  @@index([storeId, status])
}

model ShippingProviderCredential {
  id                        String                 @id @default(cuid())
  providerConfigId          String
  type                      ShippingCredentialType @default(DEFAULT)
  // Secret alanlar AES-256-GCM ciphertext olarak saklanir; duz metin ASLA yazilmaz.
  // DHL IDENTITY tipi ayrica customerNumber/customerPassword tutar.
  encryptedKey              String?
  encryptedSecret           String?
  encryptedCustomerNumber   String?
  encryptedCustomerPassword String?
  identityType              Int?
  // maskedKey yalnizca son-4 gosterimi icin; tam secret degildir.
  maskedKey                 String?
  configured                Boolean                @default(false)
  lastTestedAt              DateTime?
  lastTestStatus            String?
  lastErrorCode             String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([providerConfigId, type])
  @@index([providerConfigId])
}

model Shipment {
  id                        String               @id @default(cuid())
  storeId                   String
  orderId                   String
  providerConfigId          String
  provider                  ShippingProviderType
  externalOrderId           String?
  externalShipmentId        String?
  externalInvoiceId         String?
  referenceId               String
  status                    ShipmentStatus       @default(DRAFT)
  shipmentStatusCode        Int?
  trackingNumber            String?
  trackingUrl               String?
  labelUrl                  String?
  // Yalnizca sanitize edilmis barkod ozeti (pieceNumber + value); JWT/secret icermez.
  barcodeJsonSafe           Json?
  pieceCount                Int                  @default(1)
  totalKg                   Float                @default(0)
  totalDesi                 Float                @default(0)
  packagingType             Int?
  shipmentServiceType       Int?
  paymentType               Int?
  deliveryType              Int?
  recipientName             String?
  recipientEmail            String?
  recipientPhone            String?
  recipientCityCode         Int?
  recipientDistrictCode     Int?
  recipientCityName         String?
  recipientDistrictName     String?
  recipientAddress          String?
  // TODO-129 — zamanlanmis shipment sync worker metadata'si (provider-agnostic).
  // lastSyncAt = son sync DENEMESI (basari/hata farketmez; stale-after secimi bunu esas alir).
  // nextSyncAt = hata backoff'u (null => hemen secilebilir). syncAttempts = ARDISIK hata
  // sayaci (basarida sifirlanir; MAX_ATTEMPTS ustunu worker SECMEZ, manuel sync calisir).
  // lastSyncErrorCode = sanitize hata kodu (or. PROVIDER_QUERY_FAILED,
  // PROVIDER_SYNC_UNSUPPORTED, PROVIDER_DISABLED); raw payload/secret ASLA yazilmaz.
  lastSyncAt                DateTime?
  nextSyncAt                DateTime?
  syncAttempts              Int                  @default(0)
  lastSyncErrorCode         String?
  // TODO-124 — son barkod denemesinin SINIFLANDIRILMIS hata kodu (or.
  // DESTINATION_BRANCH_NOT_FOUND, PROVIDER_ERROR). Basarili barkod/pending ve
  // varis eslemesi onarimi (repair-destination) bunu SIFIRLAR. TODO-123 retry
  // worker'i DESTINATION_BRANCH_NOT_FOUND'u admin duzeltmesine kadar SKIP etmelidir.
  // Raw saglayici mesaji/secret ASLA yazilmaz; yalniz kisa sanitize kod.
  lastBarcodeErrorCode      String?
  // TODO-123 — barkod retry/backoff metadata'si (TODO-129 sync alanlarindan AYRIDIR;
  // barkod olusturma ile durum senkronu farkli yasam donguleridir). barcodeRetryCount =
  // ardisik TRANSIENT (retryable) hata sayaci; basarili barkod/pending SIFIRLAR.
  // barcodeNextRetryAt = backoff (null => zamanlanmadi; worker SECMEZ). barcodeLastAttemptAt =
  // son barkod DENEMESI ani. barcodeRetryBlockedReason = otomatik retry BLOK nedeni:
  // "DATA_FIX" (adres/varis eslemesi duzeltilmeli — TODO-124/139), "TERMINAL" (kalici/
  // desteklenmeyen), "MAX_ATTEMPTS" (transient limit doldu). null => bloklu degil.
  // lastBarcodeErrorCode ("ne oldu") ile barcodeRetryBlockedReason ("neden otomatik
  // denenmiyor") AYRIDIR. Adres/varis onarimi (TODO-124/139) bu alanlari sifirlar.
  barcodeRetryCount         Int                  @default(0)
  barcodeNextRetryAt        DateTime?
  barcodeLastAttemptAt      DateTime?
  barcodeRetryBlockedReason String?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  events         ShipmentEvent[]

  @@unique([storeId, referenceId])
  @@index([storeId])
  @@index([orderId])
  @@index([providerConfigId])
  @@index([status])
  // TODO-129 — worker uygun gonderi secimi (status taramasi + backoff/stale siralamasi).
  @@index([status, nextSyncAt])
  @@index([status, lastSyncAt])
  // TODO-123 — barkod retry worker'inin uygun gonderi secimi (status + backoff siralamasi).
  @@index([status, barcodeNextRetryAt])
  @@index([lastBarcodeErrorCode, barcodeNextRetryAt])
}

model ShipmentEvent {
  id          String               @id @default(cuid())
  storeId     String
  shipmentId  String
  provider    ShippingProviderType
  eventType   ShipmentEventType
  statusCode  Int?
  statusText  String?
  location    String?
  occurredAt  DateTime?
  trackingUrl String?
  // Yalnizca sanitize edilmis saglayici payload ozeti; secret/JWT/Authorization icermez.
  rawSafeJson Json?
  createdAt   DateTime             @default(now())

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([shipmentId])
  @@index([eventType])
}

// TODO-104 — Webhook idempotency/replay inbox'i. Imzasi GECERLI her teslimat
// (providerConfigId, eventKey) ile BIR KEZ kaydedilir; unique ihlali = duplicate →
// yeni ShipmentEvent YAZILMAZ (idempotent). Gecersiz imzali istekler buraya
// YAZILMAZ (DB flood/DoS onlemi; yalniz log). statusText sanitize ozet tasir;
// secret/imza/raw payload ASLA saklanmaz (payloadHash sha256 ozetidir).
model ShipmentWebhookInbox {
  id               String                 @id @default(cuid())
  storeId          String
  providerConfigId String
  provider         ShippingProviderType
  eventKey         String
  payloadHash      String
  outcome          ShipmentWebhookOutcome @default(ACCEPTED)
  shipmentId       String?
  statusCode       Int?
  statusText       String?
  createdAt        DateTime               @default(now())

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([providerConfigId, eventKey])
  @@index([storeId])
  @@index([shipmentId])
}

model ShipmentQuote {
  id               String               @id @default(cuid())
  storeId          String
  orderId          String?
  providerConfigId String
  provider         ShippingProviderType
  amountMinor      Int
  currency         String               @default("TRY")
  // Yalnizca sanitize edilmis ucret kalemleri ozeti; secret icermez.
  rawSafeJson      Json?
  createdAt        DateTime             @default(now())

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order          Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([providerConfigId])
}

// ─────────────────────── F3C.2 Shipping price engine (store tarife) ───────────────────────
// Magaza bazli kargo tarife plani. Kargo ucreti bu plan + kurallar uzerinden
// hesaplanir; SAGLAYICI canli quote DEGILDIR (bkz. ADR-036). Tek default guard
// uygulama katmanindadir (Prisma partial unique olmadigi icin set-default
// transaction'inda digerleri kapatilir).
model ShippingRatePlan {
  id                         String                  @id @default(cuid())
  storeId                    String
  // Operasyon sağlayıcısıyla gevsek iliskilendirme (UI/rapor icin); fiyat etkisi YOK.
  provider                   ShippingProviderType?
  name                       String
  status                     ShippingRatePlanStatus  @default(ACTIVE)
  isDefault                  Boolean                 @default(false)
  pricingMode                ShippingRatePricingMode @default(FIXED)
  currency                   String                  @default("TRY")
  fixedAmountMinor           Int?
  freeShippingThresholdMinor Int?
  // TODO-125 (ADR-047) — Checkout kargo seçeneği kartında gösterilecek tahmini
  // teslim metni (ör. "2-3 iş günü"). PUBLIC, opsiyonel; sipariş snapshot'ına yazılır.
  deliveryEstimate           String?
  validFrom                  DateTime?
  validTo                    DateTime?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rules      ShippingRateRule[]
  tiers      ShippingRateTier[]
  zones      ShippingRateZone[]
  surcharges ShippingSurcharge[]

  @@index([storeId])
  @@index([storeId, status])
}

// F3C.2 revizyon — Aylik gonderi hacmi segmenti / sozlesme grubu (DHL Tarife I/II/III).
// Bir kural tierId ile bu segmente baglanir; tier secimi monthlyShipmentCount'a gore
// yapilir (bilinmiyorsa en kucuk sortOrder; ADR-044). storeId yok — plan'a kapsali.
model ShippingRateTier {
  id                 String   @id @default(cuid())
  ratePlanId         String
  name               String
  monthlyShipmentMin Int?
  monthlyShipmentMax Int?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ratePlan ShippingRatePlan   @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  rules    ShippingRateRule[]

  @@index([ratePlanId])
}

// F3C.2 revizyon — Mesafe/bolge zonu (Aras sehir-ici/yakin/kisa/orta/uzak/KKTC/MOBILE).
// code plan icinde unique. Kural zoneId ile baglanir; ince geo (city/district) ayrica
// ShippingRateRule uzerinde korunur. minDistanceKm/maxDistanceKm ilerideki firma bolge
// tablolari icin opsiyonel.
model ShippingRateZone {
  id            String   @id @default(cuid())
  ratePlanId    String
  code          String
  name          String
  minDistanceKm Decimal? @db.Decimal(10, 2)
  maxDistanceKm Decimal? @db.Decimal(10, 2)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ratePlan ShippingRatePlan   @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  rules    ShippingRateRule[]

  @@unique([ratePlanId, code])
  @@index([ratePlanId])
}

// F3C.2 revizyon — Ek hizmet bedelleri (SMS bildirim, taşıma güvencesi, mobil alan,
// hamaliye, agir gonderi, kapida odeme farki). chargeType FLAT/PER_KG/PER_DESI/...
// olabilir. isOptional=false ise her quote'a eklenir; true ise conditionJsonSafe
// degerlendirilir (SQL-injection riski yok; saf JSON, sadece engine tarafindan okunur).
model ShippingSurcharge {
  id                String             @id @default(cuid())
  ratePlanId        String
  code              String
  name              String
  chargeType        ShippingChargeType @default(FLAT)
  amountMinor       Int?
  unitAmountMinor   Int?
  conditionJsonSafe Json?
  isOptional        Boolean            @default(false)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  ratePlan ShippingRatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([ratePlanId, code])
  @@index([ratePlanId])
}

model ShippingRateRule {
  id               String             @id @default(cuid())
  ratePlanId       String
  storeId          String
  tierId           String?
  zoneId           String?
  minDesi          Decimal?           @db.Decimal(10, 2)
  maxDesi          Decimal?           @db.Decimal(10, 2)
  minWeightKg      Decimal?           @db.Decimal(10, 3)
  maxWeightKg      Decimal?           @db.Decimal(10, 3)
  cityCode         String?
  districtCode     String?
  regionCode       String?
  // chargeType FLAT (varsayilan) mevcut amountMinor yolunu birebir korur. Yeni
  // tipler unitAmountMinor / baseAmountMinor / baseThreshold kullanir. amountMinor
  // artik nullable (FLAT disinda zorunlu degil); mevcut veriler backfill ile korunur.
  chargeType       ShippingChargeType @default(FLAT)
  amountMinor      Int?
  unitAmountMinor  Int?
  baseAmountMinor  Int?
  baseThreshold    Decimal?           @db.Decimal(10, 2)
  // Legacy/simple-extra: yeni gelismis hesabin merkezi DEGIL; ek ucretler
  // ShippingSurcharge ile yonetilir (ADR-044 revizyon). Geriye uyumluluk icin korunur.
  extraAmountMinor Int?
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  store    Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ratePlan ShippingRatePlan  @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  tier     ShippingRateTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  zone     ShippingRateZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([ratePlanId])
  @@index([cityCode, districtCode])
  @@index([storeId])
  @@index([tierId])
  @@index([zoneId])
}

// ─────────────────────── F4A Campaigns & Coupons MVP ───────────────────────
// Kampanya: magaza-scoped indirim tanimi. discountValue PERCENT'te 1-100 tam
// sayi yuzdedir; FIXED_AMOUNT'ta minor unit (kurus) tutardir. usageCount toplam
// kullanim limiti icin ATOMIK sayactir (siparis transaction'inda kosullu
// UPDATE ile artirilir; limit asilirsa siparis reddedilir — ADR-058).
model Campaign {
  id                     String                @id @default(cuid())
  storeId                String
  name                   String
  description            String?
  status                 CampaignStatus        @default(DRAFT)
  type                   CampaignType
  discountType           CampaignDiscountType
  discountValue          Int
  maxDiscountAmountMinor Int?
  minOrderAmountMinor    Int?
  startsAt               DateTime?
  endsAt                 DateTime?
  totalUsageLimit        Int?
  perCustomerUsageLimit  Int?
  usageCount             Int                   @default(0)
  stackable              Boolean               @default(false)
  priority               Int                   @default(0)
  isPublic               Boolean               @default(true)
  // F4A.4 — SUNUM alanlari (ADR-061). Yalnizca kupon kart/rozet gorunumu;
  // indirim hesaplamasini ETKILEMEZ. Mevcut kampanyalar null ile calisir
  // (UI fallback uretilmis etiketlere doner).
  displayTitle           String?
  shortDescription       String?
  terms                  String?
  badgeLabel             String?
  badgeVariant           CampaignBadgeVariant?
  cardStyle              CampaignCardStyle     @default(STANDARD)
  accessModel            CampaignAccessModel   @default(AUTO_VISIBLE)
  // Sunum siralamasi (calc `priority`den AYRI; motor bunu kullanmaz).
  displayPriority        Int                   @default(0)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  store           Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coupons         Coupon[]
  products        CampaignProduct[]
  categories      CampaignCategory[]
  redemptions     CampaignRedemption[]
  orderDiscounts  OrderDiscount[]
  customerCoupons CustomerCoupon[]

  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, type])
}

// Kupon kodu: store scope'unda normalizedCode UNIQUE (farkli magazalar ayni
// kodu kullanabilir). normalizedCode = trim + locale-BAGIMSIZ uppercase
// (TR-I tuzagina karsi izinli karakterler [A-Z0-9_-]). startsAt/endsAt
// kampanya penceresini DARALTAN opsiyonel override'dir.
model Coupon {
  id                    String       @id @default(cuid())
  storeId               String
  campaignId            String
  code                  String
  normalizedCode        String
  status                CouponStatus @default(ACTIVE)
  totalUsageLimit       Int?
  perCustomerUsageLimit Int?
  usageCount            Int          @default(0)
  startsAt              DateTime?
  endsAt                DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  store           Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign        Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  redemptions     CampaignRedemption[]
  orderDiscounts  OrderDiscount[]
  customerCoupons CustomerCoupon[]

  @@unique([storeId, normalizedCode])
  @@index([storeId])
  @@index([campaignId])
}

// Kampanya urun kapsami. Bos kapsam = tum sepet. Scope id'leri ayni store'a
// ait olmalidir (uygulama katmaninda dogrulanir; storeId kolonu izolasyon
// sorgulari icindir).
model CampaignProduct {
  campaignId String
  productId  String
  storeId    String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([campaignId, productId])
  @@index([storeId])
  @@index([productId])
}

model CampaignCategory {
  campaignId String
  categoryId String
  storeId    String
  createdAt  DateTime @default(now())

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([campaignId, categoryId])
  @@index([storeId])
  @@index([categoryId])
}

// Kullanim kaydi: siparis olusturma transaction'inda yazilir; siparis basina
// kampanya BIR KEZ (unique). Siparis sonradan iptal/refund olsa da kayit
// TARIHSEL kalir (kompanzasyon deseni yok — ADR-058'de dokumante sinirlama).
// email: misafir checkout'ta per-customer limit dayanagi (customerId yoksa).
model CampaignRedemption {
  id                  String   @id @default(cuid())
  storeId             String
  campaignId          String
  couponId            String?
  orderId             String
  customerId          String?
  email               String?
  discountAmountMinor Int
  createdAt           DateTime @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  coupon   Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([campaignId, orderId])
  @@index([storeId])
  @@index([couponId])
  @@index([campaignId, customerId])
  @@index([campaignId, email])
  @@index([orderId])
}

// Siparis indirim SNAPSHOT satiri (immutable; siparis olusturulduktan sonra
// degistirilmez — ADR-058). Kampanya/kupon sonradan silinse/degisse bile
// siparis gecmisi sabit kalir; bu yuzden label/code/discountType kopyalanir.
model OrderDiscount {
  id                  String               @id @default(cuid())
  storeId             String
  orderId             String
  campaignId          String?
  couponId            String?
  code                String?
  label               String
  discountType        CampaignDiscountType
  discountValue       Int
  discountAmountMinor Int
  scopeSummary        Json?
  createdAt           DateTime             @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  coupon   Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([orderId])
  @@index([campaignId])
}

// F4A.3 — Musteri kupon cuzdani (ADR-060). Bir kupon satiri BIR musteri
// (customerId) VEYA bir email icin tutulur. status yasam dongusu:
// AVAILABLE -> APPLIED (sepette "Kullan") -> USED (siparis basarili) / geri
// AVAILABLE ("Kaldir"); REVOKED admin geri-alimidir. KAYNAK DOGRUSU indirim
// tutari icin DEGILDIR — indirim yine couponCode + motordan gelir; bu tablo
// yalnizca cuzdan/atama/claim state'idir. Store-scoped; cross-store gorunmez.
model CustomerCoupon {
  id         String               @id @default(cuid())
  storeId    String
  couponId   String
  campaignId String
  customerId String?
  email      String?
  status     CustomerCouponStatus @default(AVAILABLE)
  source     CustomerCouponSource
  claimedAt  DateTime             @default(now())
  appliedAt  DateTime?
  usedAt     DateTime?
  orderId    String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coupon   Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Ayni kupon ayni musteri/email icin TEK satir (lifecycle in-place gunceller).
  // Postgres NULL-distinct oldugundan customerId=null satirlar email kisitiyla,
  // email=null satirlar customerId kisitiyla korunur; uygulama katmani da dedup yapar.
  @@unique([storeId, couponId, customerId])
  @@unique([storeId, couponId, email])
  @@index([storeId])
  @@index([couponId])
  @@index([campaignId])
  @@index([storeId, customerId, status])
  @@index([storeId, email, status])
}

// ============================================================================
// ADR-065 — Site-geneli gorsel yonetimi (Faz 1: sema + storage + upload API).
// Ilke: "storage key sakla, URL turet" — DB'ye tam URL YAZILMAZ; yalniz goreli
// storageKey saklanir, public URL runtime'da MEDIA_PUBLIC_BASE_URL + storageKey
// ile uretilir (CDN-hazir, migration'siz gecis). Multi-tenant izolasyon mevcut
// desenle: storeId FK + onDelete Cascade + @@index([storeId]).
// ============================================================================

// Merkezi/polimorfik yukleme kaydi. storageKey formati (entityId ICERMEZ; entity
// baglama tamamen DB iliskisiyle yapilir, dosya tasima gerekmez):
//   stores/{storeId}/{context}/{uuid}.webp
// context = products | categories | hero | branding. Tum gorseller yuklemede
// sunucuda webp'e normalize edilir (sharp), bu yuzden mimeType daima image/webp.
model MediaAsset {
  id         String       @id @default(cuid())
  storeId    String
  context    MediaContext
  storageKey String       @unique
  mimeType   String
  byteSize   Int
  width      Int?
  height     Int?
  altText    String?
  checksum   String? // sha256; dedup/butunluk (dedup mantigi Faz 4)
  createdBy  String? // yukleyen actorUserId (audit)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  store                  Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productImages          ProductImage[]
  categoryLinks          ProductCategory[]       @relation("CategoryImage")
  heroSlides             HeroSlide[]
  logoSettings           StoreSettings[]         @relation("StoreLogo")
  faviconSettings        StoreSettings[]         @relation("StoreFavicon")
  // Faz 2A (ADR-068) — IMAGE/FILE attribute degeri olarak kullanan urun satirlari
  // (onDelete: Restrict; media silme ucu MEDIA_IN_USE guard'i ile korunur).
  productAttributeValues ProductAttributeValue[]

  @@index([storeId])
  @@index([storeId, context])
}

// Urun galerisi (coklu, sirali). position=0 kapak. storeId denormalize tenant
// sutunudur (FK degil) — ProductCategoryAssignment deseniyle tutarli.
model ProductImage {
  id                    String   @id @default(cuid())
  storeId               String
  productId             String
  mediaId               String
  position              Int      @default(0)
  // Faz 2C-7 (ADR-078) — Variant Media Engine. Bu gorselin ait oldugu media-tanimlayici
  // eksen degeri (genelde Renk option'i). Ikisi de null = "Tum varyantlar" (paylasilan gorsel,
  // her varyant grubuyla birlikte gosterilir). attributeDefinitionId denormalize: optionId'nin
  // hangi eksende oldugunu tasir + Product.mediaDefiningAttributeId ile tutarlilik dogrulamasi
  // (service). Bu faz tek-option (1 gorsel -> en fazla 1 renk); coklu-option/coklu-eksen gerekince
  // ProductImageOption join tablosuna yukseltme yolu acik (yalniz persistence degisir, is kurallari
  // degismez). onDelete: Restrict → kullanimdaki option/eksen silinemez (MEDIA_IN_USE deseniyle tutarli).
  attributeDefinitionId String?
  optionId              String?
  createdAt             DateTime @default(now())

  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  media               MediaAsset           @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  attributeDefinition AttributeDefinition? @relation("ProductImageMediaAxis", fields: [attributeDefinitionId], references: [id], onDelete: Restrict)
  option              AttributeOption?     @relation("ProductImageMediaOption", fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([productId, mediaId])
  @@index([storeId])
  @@index([productId])
  // Faz 2C-7 (ADR-078) — varyant renk grubu filtreleme (galeri projeksiyonu, N+1-siz).
  @@index([productId, optionId])
}

// Ana sayfa hero/slider (coklu slide). Model cokludur; UI tek slide ile baslar,
// CampaignBar'in coklu-slide UX mantigi (auto-gecis/ok/nokta) referans alinir.
model HeroSlide {
  id        String        @id @default(cuid())
  storeId   String
  mediaId   String
  position  Int           @default(0)
  status    ContentStatus @default(DRAFT)
  headline  String?
  subtext   String?
  ctaLabel  String?
  ctaHref   String?
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  media MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
}

// Magaza ayarlari (1-1; repoda ilk 1-1 iliski). Logo/favicon MediaAsset'e opsiyonel
// FK. Ileride tema/renk/SEO default'lari da buraya eklenir. PK = FK (storeId).
model StoreSettings {
  storeId        String   @id
  logoMediaId    String?
  faviconMediaId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store   Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  logo    MediaAsset? @relation("StoreLogo", fields: [logoMediaId], references: [id], onDelete: SetNull)
  favicon MediaAsset? @relation("StoreFavicon", fields: [faviconMediaId], references: [id], onDelete: SetNull)

  @@index([logoMediaId])
  @@index([faviconMediaId])
}

// ─────────────────────── Faz 1B (ADR-067) — Attribute katalog cekirdegi ───────────────────────
// Kategoriye-bagli dinamik urun ozelliklerinin KATALOG temeli. Bu faz yalniz TANIM
// katmanidir: urun/varyant deger tablolari (ProductAttributeValue vb.) KAPSAM DISI.
// Kategori mirasi ve overrideMode UYGULANMAZ (ADR-067 md.7, YAGNI).

// Attribute TANIMI. scope=PLATFORM (tum magazalar, storeId null, yalniz SUPER_ADMIN)
// veya scope=STORE (tek magaza, storeId zorunlu, ilgili store admin). `code` immutable
// (service guard); `dataType` kullanim basladiktan sonra immutable (service guard).
// Davranis TASIMAZ — davranis yalniz CategoryAttribute'ta tutulur (tek sahip).
model AttributeDefinition {
  id          String            @id @default(cuid())
  scope       AttributeScope
  // PLATFORM => null; STORE => zorunlu (route katmani doldurur). Composite unique
  // ([storeId, code]) STORE cakismasini DB'de yakalar; PLATFORM (null storeId) icin
  // Postgres NULL'lari distinct saydigindan duplicate-code route katmaninda kontrol
  // edilir (kategori slug deseniyle ayni).
  storeId     String?
  code        String
  name        String
  description String?
  dataType    AttributeDataType
  unit        String?
  status      AttributeStatus   @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  store                 Store?                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  options               AttributeOption[]
  categoryLinks         CategoryAttribute[]
  // Faz 2A (ADR-068) — bu tanimi DEGER olarak kullanan urun/varyant satirlari (onDelete: Restrict).
  productValues         ProductAttributeValue[]
  variantValues         VariantAttributeValue[]
  // Faz 2C-1 (ADR-070) — bu tanimi variant-defining EKSEN olarak secen urun satirlari (onDelete: Restrict).
  variantSelectionLinks ProductVariantAttribute[]
  // Faz 2C-3 (ADR-072) — bu tanimi uretilmis varyant eksen degeri olarak kullanan satirlar (onDelete: Restrict).
  variantOptionValues   ProductVariantOptionValue[]
  // Faz 2C-7 (ADR-078) — bu tanimi media-tanimlayici EKSEN olarak secen urunler (onDelete: SetNull).
  mediaAxisProducts     Product[]                   @relation("ProductMediaAxis")
  // Faz 2C-7 (ADR-078) — bu eksene etiketli varyant-media gorselleri (onDelete: Restrict).
  productImageLinks     ProductImage[]              @relation("ProductImageMediaAxis")

  @@unique([storeId, code])
  @@index([storeId])
  @@index([scope])
  @@index([status])
}

// Attribute GRUBU — store-scoped sunum/organizasyon kabi ( or. "Teknik ozellikler").
// CategoryAttribute opsiyonel olarak bir gruba baglanir (groupId). Davranis tasimaz.
model AttributeGroup {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store         Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryLinks CategoryAttribute[]

  @@index([storeId])
}

// SELECT / MULTI_SELECT / COLOR tipli attribute'larin secenekleri. definition'a bagli
// (silinirse Cascade). storeId: STORE attribute seceneginde ilgili magaza, PLATFORM
// attribute seceneginde null. `value` bir tanim icinde benzersiz (duplicate option
// value DB'de yakalanir). colorHex yalniz COLOR icin anlamli (opsiyonel).
model AttributeOption {
  id                    String          @id @default(cuid())
  attributeDefinitionId String
  storeId               String?
  value                 String
  label                 String
  colorHex              String?
  sortOrder             Int             @default(0)
  status                AttributeStatus @default(ACTIVE)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  definition              AttributeDefinition             @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)
  store                   Store?                          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  // Faz 2A (ADR-068) — bu secenegi DEGER olarak kullanan satirlar (onDelete: Restrict).
  productValues           ProductAttributeValue[]
  variantValues           VariantAttributeValue[]
  productValueLinks       ProductAttributeValueOption[]
  // Faz 2C-1 (ADR-070) — bu secenegi variant eksen option'i olarak secen satirlar (onDelete: Restrict).
  variantOptionSelections ProductVariantOptionSelection[]
  // Faz 2C-3 (ADR-072) — bu secenegi uretilmis varyant eksen degeri olarak kullanan satirlar (onDelete: Restrict).
  variantOptionValues     ProductVariantOptionValue[]
  // Faz 2C-7 (ADR-078) — bu option'a (renk) etiketli varyant-media gorselleri (onDelete: Restrict).
  productImages           ProductImage[]                  @relation("ProductImageMediaOption")

  @@unique([attributeDefinitionId, value])
  @@index([attributeDefinitionId])
  @@index([storeId])
}

// Bir attribute'un bir KATEGORI kapsamindaki davranisinin TEK SAHIBI. AttributeDefinition
// (PLATFORM veya STORE) tek bir kategoriye en fazla bir kez baglanir. Tum davranis
// bayraklari + validationRules burada; AttributeDefinition davranis tasimaz. Kategori
// mirasi/overrideMode YOK (ADR-067 md.7).
model CategoryAttribute {
  id                    String  @id @default(cuid())
  storeId               String
  categoryId            String
  attributeDefinitionId String
  groupId               String?

  required             Boolean @default(false)
  filterable           Boolean @default(false)
  searchable           Boolean @default(false)
  comparable           Boolean @default(false)
  variantDefining      Boolean @default(false)
  visibleOnProductPage Boolean @default(true)
  visibleOnListing     Boolean @default(false)

  displayOrder    Int  @default(0)
  validationRules Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   ProductCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  definition AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Cascade)
  group      AttributeGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([categoryId, attributeDefinitionId])
  @@index([storeId])
  @@index([categoryId])
  @@index([attributeDefinitionId])
  @@index([groupId])
}

// ─────────────────────── Faz 2A (ADR-068) — Urun/varyant attribute DEGER tablolari ───────────────────────
// Faz 1B katalog TANIMINI (AttributeDefinition + CategoryAttribute davranisi) tuketip
// urun ve varyantlarin gercek attribute DEGERLERINI saklar. TUM yazimlar tek nokta olan
// `attributeValueService`'ten gecer (route dogrudan Prisma'ya yazmaz). Tip guvenli
// saklama: her dataType icin AYRI kolon (JSON kullanilmaz); bir satirda EN FAZLA bir
// deger kolonu dolu olabilir (DB CHECK + servis). MULTI_SELECT degeri junction tabloda
// (deger kolonlari bos kalir). combinationKey / otomatik varyant / order snapshot Faz 2B+.

// Bir urunun bir attribute icin DEGERI. dataType -> kolon eslemesi (servis otoritesi):
//  TEXT/TEXTAREA/RICH_TEXT/URL -> valueText, INTEGER -> valueInteger, DECIMAL -> valueDecimal,
//  BOOLEAN -> valueBoolean, DATE -> valueDate, SELECT/COLOR -> optionId, IMAGE/FILE -> mediaId,
//  MULTI_SELECT -> ProductAttributeValueOption (junction; tum deger kolonlari bos).
// storeId denormalize tenant sutunudur. definition/option/media onDelete: Restrict
// (kullanimda olan tanim/secenek/gorsel silinemez — katalog usage-guard felsefesi).
model ProductAttributeValue {
  id                    String @id @default(cuid())
  storeId               String
  productId             String
  attributeDefinitionId String

  // Tip guvenli deger kolonlari — bir satirda EN FAZLA biri dolu (DB CHECK + servis).
  valueText    String?
  valueInteger Int?
  valueDecimal Decimal?  @db.Decimal(20, 6)
  valueBoolean Boolean?
  valueDate    DateTime?
  optionId     String? // SELECT / COLOR
  mediaId      String? // IMAGE / FILE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store       Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product     Product                       @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition  AttributeDefinition           @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)
  option      AttributeOption?              @relation(fields: [optionId], references: [id], onDelete: Restrict)
  media       MediaAsset?                   @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  optionLinks ProductAttributeValueOption[]

  // Bir urun + attribute en fazla bir kez (deger tekildir; MULTI_SELECT'te coklu secenek
  // junction'da tutulur, parent yine tekildir).
  @@unique([productId, attributeDefinitionId])
  @@index([storeId])
  @@index([productId])
  @@index([attributeDefinitionId])
  @@index([optionId])
  @@index([mediaId])
}

// Bir varyantin bir attribute icin DEGERI. YALNIZ variantDefining attribute'lar burada
// tutulur (servis guard). Deger yalnizca metin (valueText) veya secenek (optionId)
// olabilir — MULTI_SELECT/IMAGE/FILE variant tablosuna yazilmaz. combinationKey UYGULANMAZ.
model VariantAttributeValue {
  id                    String @id @default(cuid())
  storeId               String
  variantId             String
  attributeDefinitionId String

  valueText String? // TEXT/TEXTAREA/RICH_TEXT/URL
  optionId  String? // SELECT / COLOR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant    ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  definition AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)
  option     AttributeOption?    @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([variantId, attributeDefinitionId])
  @@index([storeId])
  @@index([variantId])
  @@index([attributeDefinitionId])
  @@index([optionId])
}

// MULTI_SELECT icin junction: bir ProductAttributeValue (parent) <-> secilen AttributeOption'lar.
// JSON KULLANILMAZ (iliskisel butunluk + gelecekte faceted-filtre icin sorgulanabilir).
// parent silinince Cascade; secenek Restrict (kullanimdaki secenek silinemez).
model ProductAttributeValueOption {
  id                      String @id @default(cuid())
  storeId                 String
  productAttributeValueId String
  optionId                String

  createdAt DateTime @default(now())

  store  Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  value  ProductAttributeValue @relation(fields: [productAttributeValueId], references: [id], onDelete: Cascade)
  option AttributeOption       @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([productAttributeValueId, optionId])
  @@index([storeId])
  @@index([productAttributeValueId])
  @@index([optionId])
}

// ─────────────────────── Faz 2C-1 (ADR-070) — Varyant motoru TEMELI (eksen secimi) ───────────────────────
// Bir urunun hangi variant-defining attribute'lari EKSEN (axis) olarak kullanacagini ve her
// eksen altinda hangi AttributeOption'lari kapsayacagini NORMALIZE saklar (JSON YOK). Bu faz
// KOMBINASYON URETMEZ: ProductVariant / combinationKey / Cartesian / SKU matris OLUSTURULMAZ.
// Gelecekteki Combination Engine bu iki tabloyu (eksenler × secilen option'lar) okuyup Cartesian
// carpimini uretecek. Yazimlar TEK NOKTA olan `variantSelectionService`'ten gecer (route dogrudan
// Prisma'ya yazmaz — Faz 2A attributeValueService deseni). Yalniz option-tabanli (SELECT/COLOR)
// variantDefining=true CategoryAttribute eksen olabilir (VariantAttributeValue tek option tasir →
// eksen tek-secimli olmali); dogrulama servistedir.

// Bir urunde EKSEN olarak secilen variant-defining attribute. Bir urun + attribute en fazla bir kez.
// definition onDelete: Restrict (eksen olarak kullanilan tanim silinemez — katalog usage-guard
// felsefesi, Faz 2A ile tutarli); product/store Cascade. storeId denormalize tenant sutunu.
model ProductVariantAttribute {
  id                    String @id @default(cuid())
  storeId               String
  productId             String
  attributeDefinitionId String
  // Eksenlerin admin-tanimli sirasi (UI displayOrder; ileride kombinasyon ekseni sirasi).
  position              Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store      Store                           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product    Product                         @relation(fields: [productId], references: [id], onDelete: Cascade)
  definition AttributeDefinition             @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)
  options    ProductVariantOptionSelection[]

  @@unique([productId, attributeDefinitionId])
  @@index([storeId])
  @@index([productId])
  @@index([attributeDefinitionId])
}

// Bir varyant ekseni (ProductVariantAttribute) altinda KAPSANAN AttributeOption. Bir eksen +
// option en fazla bir kez. option onDelete: Restrict (kullanimdaki secenek silinemez); parent/store
// Cascade. En az bir option zorunlulugu servistedir (DB CHECK ile ifade edilemez — cross-row).
model ProductVariantOptionSelection {
  id                        String @id @default(cuid())
  storeId                   String
  productVariantAttributeId String
  optionId                  String
  // Option'larin admin-tanimli sirasi (UI displayOrder).
  position                  Int    @default(0)

  createdAt DateTime @default(now())

  store     Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  attribute ProductVariantAttribute @relation(fields: [productVariantAttributeId], references: [id], onDelete: Cascade)
  option    AttributeOption         @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([productVariantAttributeId, optionId])
  @@index([storeId])
  @@index([productVariantAttributeId])
  @@index([optionId])
}

// ─────────────────────── Faz 2C-3 (ADR-072) — Uretilmis varyantin cozulmus eksen->option secimi ───────────────────────
// Bir ATTRIBUTE_COMBINATION varyantinin hangi eksen (attributeDefinitionId) icin hangi AttributeOption'i
// temsil ettigini NORMALIZE saklar (JSON YOK; optionValues authoritative DEGIL). combinationKey ile
// tutarlidir (ayni pairlar). Bir varyant + attribute en fazla bir kez (@@unique) → cift deger onlenir.
// YAZMA OTORITESI variant-generation persistence-service'tir (2A VariantAttributeValue'dan AYRIDIR —
// oranin tek yazicisi attributeValueService; single-writer invariantlari karismasin diye ayri tablo).
// definition/option onDelete: Restrict (kullanimdaki tanim/secenek silinemez — katalog usage-guard);
// variant/store Cascade. archive/restore bu satirlara DOKUNMAZ (yalniz create yazar, cascade delete siler).
model ProductVariantOptionValue {
  id                    String @id @default(cuid())
  storeId               String
  variantId             String
  attributeDefinitionId String
  optionId              String

  createdAt DateTime @default(now())

  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant    ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  definition AttributeDefinition @relation(fields: [attributeDefinitionId], references: [id], onDelete: Restrict)
  option     AttributeOption     @relation(fields: [optionId], references: [id], onDelete: Restrict)

  @@unique([variantId, attributeDefinitionId])
  @@index([storeId])
  @@index([variantId])
  @@index([attributeDefinitionId])
  @@index([optionId])
}

// ─────────────────────── TODO-150 (ADR-073) — Identity Management Engine ───────────────────────
// Bir bulk-apply'da degistirilebilen kimlik alani. Bu faz SKU|BARCODE|TITLE aktif; GTIN/EAN/UPC/
// ERP/marketplace ileride bu enum'a EKLENEREK (alan-agnostik motor) genisler.
enum VariantIdentityField {
  SKU
  BARCODE
  TITLE
}

// Identity Engine bulk-apply audit'i (APPEND-ONLY). Her degisen alan icin bir satir; hepsi tek bir
// batchId paylasir (apply basina bir cuid, tek transaction) → UNDO metadata temeli (bir batch'i yukle,
// oldValue'lari geri yaz). changedByPlatformUserId FK DEGIL, dogrudan scalar: kullanici silinse bile
// tarihsel kayit korunur (ProductPriceChange deseni). pattern: uygulanan ham kural (echo/tani).
// store/product/variant onDelete Cascade (varyant silinirse audit de gider — tarihsel referans yok).
model VariantIdentityChange {
  id                      String               @id @default(cuid())
  storeId                 String
  productId               String
  variantId               String
  batchId                 String
  field                   VariantIdentityField
  oldValue                String?
  newValue                String?
  pattern                 String?
  changedByPlatformUserId String?
  createdAt               DateTime             @default(now())

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([variantId])
  @@index([batchId])
}

// TODO-151 (ADR-074) — Commercial Engine yonetilen ticari alanlar (rule hedefi + audit alan enum'u).
enum CommercialField {
  PRICE
  COMPARE_AT_PRICE
  COST
  VAT_RATE
}

// Commercial apply kaynagi: kullanicinin dogrudan hucre duzenlemesi mi, toplu kural mi.
enum CommercialChangeSource {
  DIRECT_EDIT
  BULK_RULE
}

// Commercial Engine bulk-apply audit'i (APPEND-ONLY). Her degisen alan icin bir satir; hepsi tek bir
// batchId paylasir (apply basina bir cuid, tek transaction) → UNDO metadata temeli. oldValue/newValue
// money alanlarinda minor (kurus), VAT_RATE'te bps; currency birlikte tutulur. ruleSnapshot: BULK_RULE
// apply'inin uygulanan yapisal kurali (echo/tani; secret icermez). changedByPlatformUserId FK DEGIL,
// dogrudan scalar: kullanici silinse bile tarihsel kayit korunur (ProductPriceChange/VariantIdentityChange
// deseni). store/product/variant onDelete Cascade. Mevcut ProductVariant fiyat kolonlari DEGISMEZ;
// ProductPriceChange (F4B) da BOZULMAZ — bu ayri, alan-bazli ticari izdir.
model VariantCommercialChange {
  id                      String                 @id @default(cuid())
  storeId                 String
  productId               String
  variantId               String
  batchId                 String
  field                   CommercialField
  oldValue                Int?
  newValue                Int?
  currency                String
  source                  CommercialChangeSource
  ruleSnapshot            Json?
  changedByPlatformUserId String?
  createdAt               DateTime               @default(now())

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([productId])
  @@index([variantId])
  @@index([batchId])
  @@index([storeId, variantId, createdAt])
}

// ─────────────────────── Faz 2C-8A (ADR-079) — Search Read-Model ───────────────────────
// Turetilmis, DENORMALIZE arama okuma-modeli. SOURCE-OF-TRUTH DEGILDIR — otorite hala normal
// Product/ProductVariant/EAV/Inventory tablolaridir; bu iki tablo yalniz SearchProvider (worker/
// backfill) tarafindan turetilir ve yazilir. Hicbir public uc bu satirlari DOGRUDAN dondurmez
// (public allowlist projeksiyonu bozulmaz). Bu fazda public search/facet UCU YOKTUR — yalniz temel.
//
// Store/Product onDelete: Cascade → magaza/urun silinince read-model otomatik temizlenir (worker
// remove-job'a ek DB-seviyesi guvence; orphan kalmaz). costMinor/netPriceMinor/storageKey/mediaId
// gibi ic alanlar bu tablolara BILINCLI olarak TASINMAZ.

enum SearchAvailabilityState {
  IN_STOCK
  OUT_OF_STOCK
  // PRE_ORDER / COMING_SOON: kaynak urun/varyant bayraklari henuz YOK (Faz sonrasi). Enum bilincli
  // olarak ileriye acik birakildi — eklendiginde builder projeksiyonu genisler, migration gerekmez.
}

// Bir PUBLIC-GORUNUR (status=ACTIVE) urun basina BIR arama dokumani. Urun ACTIVE degilse dokuman
// TUTULMAZ (indexProduct remove'a duser) → gelecekteki facet count'lari kirletmez. minPrice/maxPrice
// yalniz gorunur-fiyatli ACTIVE varyantlar uzerinden; hasStock/availability Inventory Engine'den turer.
model ProductSearchDocument {
  id                String                   @id @default(cuid())
  storeId           String
  productId         String                   @unique
  primaryCategoryId String?
  title             String
  slug              String
  brand             String?
  // Normalize edilmis aranabilir metin (title + brand + searchable attribute degerleri + aciklama).
  // `searchVector` tsvector generated STORED kolon bundan turer (migration SQL); GIN indeks orada.
  searchText        String
  // Postgres FTS vektoru — GENERATED ALWAYS (migration). Prisma Client'ta okunmaz/yazilmaz (DB uretir).
  searchVector      Unsupported("tsvector")?
  status            ProductStatus
  minPriceMinor     Int?
  maxPriceMinor     Int?
  currency          String?
  hasStock          Boolean                  @default(false)
  availability      SearchAvailabilityState  @default(OUT_OF_STOCK)
  variantCount      Int                      @default(0)
  // ── TODO-155.1 (ADR-079) — Faz 2C-9 · Listing Projection Enrichment (ADDITIVE) ──
  // Kart gosterimi icin INDEX ANINDA deterministik snapshot'lanan TURETILMIS ticari alanlar.
  // Source-of-truth DEGIL (checkout fiyat otoritesi canli tablolardir); yalniz kart gorunumu.
  // compareAtMinor: en ucuz gorunur (numerik fiyatli) ACTIVE varyantin compareAt'i (yalniz > satis fiyati).
  // discountPercent: tek server-side formul round((compareAt-price)/compareAt*100); indirim yoksa null.
  // omnibusPreviousPriceMinor: EU Omnibus son 30 gun en dusuk SATIS fiyati (yalniz indirim aktifken); yoksa null.
  compareAtMinor            Int?
  discountPercent           Int?
  omnibusPreviousPriceMinor Int?
  // BOUNDED kart medya/swatch projection'i (SADECE kart; genel EAV/facet verisi DEGIL — o ProductFacetValue'da
  // relational kalir). storageKey'ler IC alandir (public url runtime'da turetilir; DTO'ya SIZMAZ). OpenSearch'e
  // gecis serialize'inda dogal nested doc olur. Bicim: { primaryImage, secondaryImage, swatches[], swatchTotalCount }.
  listing                   Json?
  // ── TODO-155.2 (ADR-079 Ek) — Faz 2C-9B · Campaign Badge Snapshot (ADDITIVE) ──
  // Index ANINDA paylasilan selectPublicCampaignDisplay ile snapshot'lanan PUBLIC-SAFE kampanya rozeti (BIRINCIL).
  // PDP ile AYNI "tek formul" (ADR-062) → PDP↔PLP tutarliligi. Source-of-truth DEGIL (checkout otoriter);
  // yalniz kart "Sepette" sunumu. campaign = PublicCampaignBadge JSON (allowlist; ic id/limit/priority SIZMAZ)
  // ya da null. campaignStartsAt/EndsAt = kazanan kampanyanin GECERLILIK penceresi → read-time bastirma
  // (now<start ya da now>end ise rozet gosterilmez; bayat snapshot vitrine sizmaz). Reconciliation temizler.
  campaign          Json?
  campaignStartsAt  DateTime?
  campaignEndsAt    DateTime?
  // Kaynak zaman damgalari (siralama/tani) + indeksleme metaverisi (revision her reindex'te artar).
  productCreatedAt  DateTime
  productUpdatedAt  DateTime
  indexedAt         DateTime                 @default(now())
  revision          Int                      @default(0)

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([storeId, primaryCategoryId])
  @@index([storeId, minPriceMinor])
  @@index([storeId, hasStock])
  @@index([storeId, availability])
  @@index([storeId, productCreatedAt])
  // TODO-155.2 — Reconciliation sweep: suresi gecmis kampanya snapshot'larini bounded taramak icin.
  @@index([storeId, campaignEndsAt])
}

// Flat facet IS ATI: bir (urun × filterable attribute × DEGER) satiri. YALNIZ CategoryAttribute.
// filterable=true attribute'lardan uretilir (hardcode facet YOK). Bir satirda EN FAZLA bir typed
// deger kolonu dolu (optionId | valueText | valueNumber | valueBoolean | valueDate) — builder
// invariant'i + DB CHECK (migration). Ayni urunun ayni degeri (or. coklu varyantta ayni renk)
// builder'da TEKILLESTIRILIR → duplicate satir yok. Urunun tam reindex'i delete-and-replace
// (atomik, tek transaction) — kategori/attribute degisince eski satirlar KALMAZ. categoryId =
// facet'in cikartildigi kaynak kategori (urunun primaryCategory'si).
model ProductFacetValue {
  id                    String    @id @default(cuid())
  storeId               String
  productId             String
  categoryId            String
  attributeDefinitionId String
  optionId              String?
  valueText             String?
  valueNumber           Decimal?  @db.Decimal(20, 6)
  valueBoolean          Boolean?
  valueDate             DateTime?
  // optionId/valueText degerinin normalize (lowercase/trim) hali — facet count grupla + arama zemini.
  normalizedText        String?

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Facet count'un iş atı: kategori+attribute+option grupla-say (kendi-facet-haric kurali Faz B).
  @@index([storeId, attributeDefinitionId, optionId])
  @@index([storeId, attributeDefinitionId, valueNumber])
  @@index([storeId, categoryId, attributeDefinitionId])
  @@index([storeId, productId])
}
