generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformUserRole {
  SUPER_ADMIN
  SUPPORT_ADMIN
}

enum StoreUserRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

enum StoreStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  CLOSED
}

enum DomainType {
  SYSTEM_SUBDOMAIN
  CUSTOM_DOMAIN
}

enum DomainStatus {
  PENDING
  ACTIVE
  FAILED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SYSTEM
}

enum EventType {
  STORE_CREATED
  STORE_UPDATED
  USER_INVITED
  SUBSCRIPTION_CHANGED
  SYSTEM_EVENT
}

enum QueueJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
}

enum ProductSalesMode {
  ONLINE
  INQUIRY
  APPOINTMENT
  WHATSAPP
  CATALOG_ONLY
}

enum ProductPriceVisibility {
  VISIBLE
  HIDDEN
  STARTING_FROM
  ON_REQUEST
}

enum ProductPrimaryAction {
  ADD_TO_CART
  REQUEST_PRICE
  BOOK_APPOINTMENT
  WHATSAPP
  CONTACT_FORM
  NONE
}

enum ProductCategoryStatus {
  ACTIVE
  ARCHIVED
}

enum ProductVariantStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryMovementType {
  ADJUSTMENT
  SALE_RESERVATION
  SALE_RELEASE
  RETURN
  IMPORT
}

enum CustomerStatus {
  ACTIVE
  PASSIVE
  BLOCKED
  ARCHIVED
}

// Storefront uyelik profili icin cinsiyet (F3B.3). Zorunlu degil (nullable).
enum CustomerGender {
  FEMALE
  MALE
  OTHER
}

// Musteri OTP dogrulama amaci (F3B.3). Kayit/giris/iletisim dogrulama.
enum CustomerOtpPurpose {
  REGISTER
  LOGIN
  VERIFY_CONTACT
}

// OTP teslimat kanali (F3B.3). Gercek saglayici yok; dev/mock provider-ready.
enum CustomerOtpChannel {
  EMAIL
  SMS
}

// Admin tetikli credential token amaci (TODO-087, ADR-035). ADMIN_ACTIVATION:
// credential'i olmayan musteriye uyelik hesabi actirir + ACTIVE yapar.
// ADMIN_PASSWORD_RESET: mevcut credential'in parolasini yeniler.
enum CustomerCredentialTokenPurpose {
  ADMIN_ACTIVATION
  ADMIN_PASSWORD_RESET
}

enum AddressType {
  SHIPPING
  BILLING
}

enum BillingType {
  INDIVIDUAL
  CORPORATE
}

enum OrderStatus {
  DRAFT
  PLACED
  CONFIRMED
  CANCELLED
  FULFILLED
}

enum PaymentStatus {
  UNPAID
  AUTHORIZED
  PAID
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
  CANCELLED
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

enum PaymentProviderType {
  MOCK
  IYZICO
  STRIPE
  PAYTR
  GENERIC_REDIRECT
}

enum PaymentProviderMode {
  TEST
  LIVE
}

enum PaymentMethodType {
  CARD
  BANK_TRANSFER
  CASH_ON_DELIVERY
  PAYMENT_LINK
}

enum PaymentProviderStatus {
  ENABLED
  DISABLED
}

enum ThreeDsMode {
  DISABLED
  OPTIONAL
  REQUIRED
}

enum PaymentAttemptStatus {
  CREATED
  PENDING
  REQUIRES_ACTION
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProviderEventType {
  PAYMENT_CREATED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  PAYMENT_CANCELLED
  PAYMENT_REFUNDED
  WEBHOOK_RECEIVED
  CONNECTION_TEST
  STATUS_CHANGED
}

// ─────────────────────── F3C.1 Shipping provider foundation ───────────────────────
// Magaza bazli opsiyonel kargo saglayici altyapisi. UI/domain dilinde "DHL eCommerce"
// kullanilir; "MNG" yalnizca teknik endpoint/dokuman referansinda gecer (api.mngkargo.com.tr).
enum ShippingProviderType {
  MOCK
  GELIVER
  DHL_ECOMMERCE
}

enum ShippingProviderMode {
  TEST
  LIVE
}

enum ShippingProviderStatus {
  ENABLED
  DISABLED
}

// DHL/MNG portalinda her API urunu icin ayri "Anahtar" + "Guvenlik dizgisi" uretilebilir;
// bu yuzden config tek apiKey/secret varsaymaz, credential type bazli saklar.
enum ShippingCredentialType {
  DEFAULT
  IDENTITY
  PLUS_COMMAND
  STANDARD_COMMAND
  STANDARD_QUERY
  BARCODE_COMMAND
  CBS_INFO
  BULK_QUERY
  FINANCE_QUERY
}

// F3C.3 — DHL yanit netlestirmesi (ADR-045): DHL statusCode 0-7 normalize durumlari.
// createOrder = "DHL gonderi kaydi" (fiziksel teslim DEGIL). LABEL_PENDING = createbarcode
// HTTP 200 ama bos payload (shipmentId/barcodes yok). OUT_FOR_DELIVERY/DELIVERY_FAILED
// DHL kod 4/6. 6 (teslim edilemedi) FINAL DEGIL; takip gerektirir → ACTIVE sayilir.
enum ShipmentStatus {
  DRAFT
  ORDER_CREATED
  LABEL_PENDING
  LABEL_CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RETURNED
  CANCELLED
  FAILED
}

// TODO-104 — imzasi gecerli webhook teslimatinin isleme sonucu.
// ACCEPTED = shipment bulundu, durum/event islendi.
// IGNORED_UNKNOWN_SHIPMENT = imza gecerli ama eslesen gonderi yok (audit kaydi kalir).
// IGNORED_UNSUPPORTED = imza gecerli ama payload normalize sozlesmeye uymuyor.
enum ShipmentWebhookOutcome {
  ACCEPTED
  IGNORED_UNKNOWN_SHIPMENT
  IGNORED_UNSUPPORTED
}

enum ShipmentEventType {
  CREATED
  ORDER_CREATED
  BARCODE_CREATED
  BARCODE_PENDING
  BARCODE_FAILED
  STATUS_CHANGED
  TRACKING_UPDATED
  // F3C.5 (TODO-121) — admin manuel takip no girisi (provider-agnostic aksiyon).
  MANUAL_TRACKING
  // TODO-124 — admin varis il/ilce eslemesi duzeltmesi (CBS kodlari snapshot'a yazildi).
  DESTINATION_REPAIRED
  CANCELLED
  WEBHOOK_RECEIVED
}

// ─────────────────────── F3C.2 Shipping price engine (store tarife) ───────────────────────
// Kargo ucreti SAGLAYICI quote'u DEGILDIR; magaza/admin tarafindan girilen tarife
// uzerinden hesaplanir (bkz. ADR-036). provider yalnizca operasyon sağlayıcısıyla
// gevsek iliskilendirme icindir; fiyat provider'dan canli cekilmez.
enum ShippingRatePlanStatus {
  ACTIVE
  PASSIVE
}

enum ShippingRatePricingMode {
  FIXED
  FREE_THRESHOLD
  DESI_TABLE
  WEIGHT_TABLE
  DESI_AND_REGION_TABLE
}

enum ShippingRateSource {
  STORE_FIXED_RULE
  STORE_SHIPPING_TARIFF
  MOCK
}

// F3C.2 revizyon — Generic tariff engine ucret tipi (ADR-044). Provider'a ozel
// fiyat kodu YOKTUR; DHL/Aras/Yurtici fiyat listeleri bu generic kurallara
// maplenir. PER_ADDITIONAL_KG_OR_DESI = DHL/Aras "30+/31+" satirlarini temsil eder
// (base + esik ustu birim ucret); satirin toplam mi ek-birim mi oldugu provider
// teyidine kadar ek-birim varsayilir (docs TODO).
enum ShippingChargeType {
  FLAT
  PER_KG
  PER_DESI
  PER_KG_OR_DESI
  PER_ADDITIONAL_KG_OR_DESI
}

// ─────────────────────── F4A Campaigns & Coupons MVP ───────────────────────
// Indirim KAYNAK DOGRUSU sunucu tarafi motorudur (ADR-058); istemciden gelen
// indirim tutari ASLA kabul edilmez. Kampanya/kupon store-scoped'tur.
enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

// MVP: COUPON_CODE / AUTOMATIC_CART / PRODUCT_DISCOUNT / CATEGORY_DISCOUNT.
// BUY_X_GET_Y / FREE_SHIPPING / MEMBERSHIP_ONLY gelecek fazlar icin yalnizca
// enum rezervi; motor bu tipleri MVP'de UYGULAMAZ (bilinmeyen tip = atlanir).
enum CampaignType {
  COUPON_CODE
  AUTOMATIC_CART
  PRODUCT_DISCOUNT
  CATEGORY_DISCOUNT
  BUY_X_GET_Y
  FREE_SHIPPING
  MEMBERSHIP_ONLY
}

enum CampaignDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum CouponStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// F4A.3 — Musteri kupon cuzdani (wallet) durum/kaynak (ADR-060).
enum CustomerCouponStatus {
  AVAILABLE
  APPLIED
  USED
  REVOKED
}

enum CustomerCouponSource {
  ADMIN_ASSIGNED
  PUBLIC_CLAIMED
  CODE_CLAIMED
}

model PlatformUser {
  id           String           @id @default(cuid())
  email        String           @unique
  name         String?
  passwordHash String
  role         PlatformUserRole @default(SUPPORT_ADMIN)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  storeUsers StoreUser[]
  auditLogs  AuditLog[]
  sessions   PlatformSession[]
}

model PlatformSession {
  id             String    @id @default(cuid())
  platformUserId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  platformUser PlatformUser @relation(fields: [platformUserId], references: [id], onDelete: Cascade)

  @@index([platformUserId])
  @@index([expiresAt])
}

model Store {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  status    StoreStatus @default(DRAFT)
  metadata  Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  users         StoreUser[]
  domains       StoreDomain[]
  subscriptions Subscription[]
  products      Product[]
  variants      ProductVariant[]
  categories    ProductCategory[]
  inventory     InventoryItem[]
  movements     InventoryMovement[]
  customers     Customer[]
  customerAddresses CustomerAddress[]
  customerCredentials CustomerCredential[]
  customerCredentialTokens CustomerCredentialToken[]
  customerSessions CustomerSession[]
  customerOtpVerifications CustomerOtpVerification[]
  customerIbans CustomerIban[]
  customerCommunicationPreferences CustomerCommunicationPreference[]
  orders        Order[]
  orderLines    OrderLine[]
  orderAddresses OrderAddress[]
  orderEvents   OrderEvent[]
  orderCounters OrderNumberCounter[]
  reservations  InventoryReservation[]
  auditLogs     AuditLog[]
  eventLogs     EventLog[]
  queueJobLogs  QueueJobLog[]
  paymentProviderConfigs PaymentProviderConfig[]
  paymentAttempts        PaymentAttempt[]
  paymentProviderEvents  PaymentProviderEvent[]
  shippingProviderConfigs ShippingProviderConfig[]
  shipments               Shipment[]
  shipmentEvents          ShipmentEvent[]
  shipmentQuotes          ShipmentQuote[]
  shipmentWebhookInbox    ShipmentWebhookInbox[]
  shippingRatePlans       ShippingRatePlan[]
  shippingRateRules       ShippingRateRule[]
  campaigns               Campaign[]
  coupons                 Coupon[]
  campaignRedemptions     CampaignRedemption[]
  orderDiscounts          OrderDiscount[]
  customerCoupons         CustomerCoupon[]
}

model StoreUser {
  id             String        @id @default(cuid())
  storeId        String
  userId         String
  role           StoreUserRole @default(VIEWER)
  invitedAt      DateTime?
  acceptedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
}

model StoreDomain {
  id        String       @id @default(cuid())
  storeId   String
  domain    String       @unique
  type      DomainType   @default(SYSTEM_SUBDOMAIN)
  status    DomainStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model Plan {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  storeId   String
  planId    String
  status    SubscriptionStatus @default(TRIALING)
  startsAt  DateTime           @default(now())
  endsAt    DateTime?
  metadata  Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  plan  Plan  @relation(fields: [planId], references: [id])

  @@index([storeId])
  @@index([planId])
}

model AuditLog {
  id             String      @id @default(cuid())
  storeId        String?
  platformUserId String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  store        Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  platformUser PlatformUser? @relation(fields: [platformUserId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([platformUserId])
}

model EventLog {
  id        String    @id @default(cuid())
  storeId   String?
  type      EventType
  payload   Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([type])
}

model QueueJobLog {
  id        String         @id @default(cuid())
  storeId   String?
  jobName   String
  queueName String
  status    QueueJobStatus @default(PENDING)
  attempts  Int            @default(0)
  payload   Json?
  error     Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([queueName, jobName])
  @@index([status])
}

model Product {
  id                      String                 @id @default(cuid())
  storeId                 String
  title                   String
  slug                    String
  description             String?
  status                  ProductStatus          @default(DRAFT)
  type                    ProductType            @default(PHYSICAL)
  vendor                  String?
  brand                   String?
  seoTitle                String?
  seoDescription          String?
  salesMode               ProductSalesMode       @default(ONLINE)
  priceVisibility         ProductPriceVisibility @default(VISIBLE)
  primaryAction           ProductPrimaryAction   @default(ADD_TO_CART)
  inquiryEnabled          Boolean                @default(false)
  appointmentRequired     Boolean                @default(false)
  whatsappEnabled         Boolean                @default(false)
  purchasable             Boolean                @default(true)
  minOrderQuantity        Int                    @default(1)
  maxOrderQuantity        Int?
  callToActionLabel       String?
  whatsappMessageTemplate String?
  inquiryFormTitle        String?
  appointmentNote         String?
  // F3C.2 — Kargo olcumu (desi/agirlik). Varyant uzerindeki ayni alanlar onceliklidir;
  // burasi urun-seviyesi fallback. DESI_TABLE/WEIGHT_TABLE tarifelerinde eksikse
  // hesaplama MISSING_SHIPPING_DIMENSIONS doner (admin UI TODO-110).
  shippingWeightKg        Decimal?               @db.Decimal(10, 3)
  shippingDesi            Decimal?               @db.Decimal(10, 2)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  store       Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants    ProductVariant[]
  assignments ProductCategoryAssignment[]
  orderLines  OrderLine[]
  campaignProducts CampaignProduct[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([status])
  @@index([salesMode])
  @@index([purchasable])
}

model ProductVariant {
  id             String               @id @default(cuid())
  productId      String
  storeId        String
  title          String
  sku            String
  barcode        String?
  priceMinor     Int
  compareAtMinor Int?
  currency       String
  status         ProductVariantStatus @default(ACTIVE)
  optionValues   Json?
  // F3C.2 — Kargo olcumu (desi/agirlik); urun-seviyesi degerleri override eder.
  shippingWeightKg Decimal?           @db.Decimal(10, 3)
  shippingDesi     Decimal?           @db.Decimal(10, 2)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventory InventoryItem?
  movements InventoryMovement[]
  orderLines OrderLine[]
  reservations InventoryReservation[]

  @@unique([storeId, sku])
  @@index([productId])
  @@index([storeId])
  @@index([status])
}

model ProductCategory {
  id        String                @id @default(cuid())
  storeId   String
  name      String
  slug      String
  parentId  String?
  sortOrder Int                   @default(0)
  status    ProductCategoryStatus @default(ACTIVE)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  store       Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent      ProductCategory?            @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[]           @relation("ProductCategoryTree")
  assignments ProductCategoryAssignment[]
  campaignCategories CampaignCategory[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([parentId])
  @@index([status])
}

model ProductCategoryAssignment {
  productId  String
  categoryId String
  storeId    String
  createdAt  DateTime @default(now())

  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@unique([storeId, productId, categoryId])
  @@index([storeId])
  @@index([categoryId])
}

model InventoryItem {
  id                String   @id @default(cuid())
  storeId           String
  variantId         String   @unique
  quantityOnHand    Int      @default(0)
  quantityReserved  Int      @default(0)
  lowStockThreshold Int?
  updatedAt         DateTime @updatedAt

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([variantId])
}

model InventoryMovement {
  id            String                @id @default(cuid())
  storeId       String
  variantId     String
  type          InventoryMovementType @default(ADJUSTMENT)
  quantityDelta Int
  reason        String?
  referenceType String?
  referenceId   String?
  actorUserId   String?
  createdAt     DateTime              @default(now())

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([variantId])
  @@index([type])
}

// Storefront musteri kimligi (F3B.3). Tek kavram: hem store-admin CRM kaydi hem
// storefront uyelik hesabi ayni Customer satiridir (ADR-032). email/phone store
// scope'unda unique ve NULL'lanabilir (GSM-only ya da email-only kayit). Auth/
// profil alanlari burada; sifre/otp/session/iban/iletisim tercihi alt tablolarda.
model Customer {
  id              String          @id @default(cuid())
  storeId         String
  email           String?
  firstName       String?
  lastName        String?
  phone           String?
  birthDate       DateTime?
  gender          CustomerGender?
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  status          CustomerStatus  @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  store                   Store                          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  addresses               CustomerAddress[]
  orders                  Order[]
  credential              CustomerCredential?
  credentialTokens        CustomerCredentialToken[]
  sessions                CustomerSession[]
  otpVerifications        CustomerOtpVerification[]
  ibans                   CustomerIban[]
  communicationPreference CustomerCommunicationPreference?
  campaignRedemptions     CampaignRedemption[]
  customerCoupons         CustomerCoupon[]

  @@unique([storeId, email])
  @@unique([storeId, phone])
  @@index([storeId])
  @@index([status])
}

// Sifre kimligi (F3B.3). Plain sifre ASLA saklanmaz; scrypt hash @commerce-os/auth.
model CustomerCredential {
  id                String   @id @default(cuid())
  storeId           String
  customerId        String   @unique
  passwordHash      String
  passwordChangedAt DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// Admin tetikli aktivasyon/parola-sifirlama token'i (TODO-087, ADR-035). Plain
// token ASLA saklanmaz/loglanmaz; yalnizca sha256 tokenHash (SESSION_SECRET ile).
// Raw token yalniz uretim response'unda tek seferlik doner. createdByUserId:
// token'i ureten platform-admin. Tek seferlik: consumedAt ile tuketilir.
model CustomerCredentialToken {
  id            String                         @id @default(cuid())
  storeId       String
  customerId    String
  purpose       CustomerCredentialTokenPurpose
  tokenHash     String                         @unique
  expiresAt     DateTime
  consumedAt    DateTime?
  createdByUserId String
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([expiresAt])
}

// Musteri oturumu (F3B.3). PlatformSession deseni: raw token DB'de tutulmaz,
// yalnizca sha256 tokenHash. Storefront httpOnly cookie -> gateway server-to-server.
model CustomerSession {
  id         String    @id @default(cuid())
  storeId    String
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([expiresAt])
}

// OTP dogrulama (F3B.3). Plain kod ASLA saklanmaz/loglanmaz; yalnizca codeHash.
// destination, koda ait hedef (kullanicinin kendi email/telefonu) eslestirme icin.
model CustomerOtpVerification {
  id           String             @id @default(cuid())
  storeId      String
  customerId   String
  purpose      CustomerOtpPurpose
  channel      CustomerOtpChannel
  destination  String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([expiresAt])
}

// IBAN bilgisi (F3B.3). Iade/iptal sureci icin saklanir. DB'de tam IBAN tutulur;
// API response'larinda MASKELI doner. Event/log metadata'ya IBAN yazilmaz.
model CustomerIban {
  id                String    @id @default(cuid())
  storeId           String
  customerId        String
  accountHolderName String
  iban              String
  isDefault         Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
}

// Iletisim tercihleri (F3B.3, KVKK izin modeli). Musteri basina tek satir.
// smsEnabled = "Anlik / Kisa Mesaj"; phoneEnabled = telefon ile arama izni.
model CustomerCommunicationPreference {
  id           String   @id @default(cuid())
  storeId      String
  customerId   String   @unique
  smsEnabled   Boolean  @default(false)
  emailEnabled Boolean  @default(true)
  phoneEnabled Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

// Adres defteri (F3B.3, F3B.2 fatura ile uyumlu). Bir adres hem teslimat hem
// fatura kimligi tasiyabilir. Bireysel: tckn (11 hane); Kurumsal: companyName +
// taxOffice + taxNumber (VKN 10 hane). TCKN/VKN response'ta maskeli; log'a yazilmaz.
// Soft delete: deletedAt set edilir, satir korunur (gecmis siparis butunlugu).
model CustomerAddress {
  id           String       @id @default(cuid())
  storeId      String
  customerId   String
  type         AddressType  @default(SHIPPING)
  addressName  String       @default("")
  fullName     String
  phone        String?
  countryCode  String       @default("TR")
  city         String
  district     String?
  addressLine1 String
  addressLine2 String?
  postalCode   String?
  isDefaultShipping Boolean  @default(false)
  isDefaultBilling  Boolean  @default(false)
  billingType  BillingType?
  tckn         String?
  companyName  String?
  taxOffice    String?
  taxNumber    String?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([customerId])
  @@index([type])
}

model OrderNumberCounter {
  id        String   @id @default(cuid())
  storeId   String   @unique
  nextValue Int      @default(1)
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Order {
  id                String            @id @default(cuid())
  storeId           String
  orderNumber       String
  customerId        String?
  customerEmail     String
  currency          String
  status            OrderStatus       @default(DRAFT)
  paymentStatus     PaymentStatus     @default(UNPAID)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  subtotalAmount    Int               @default(0)
  discountAmount    Int               @default(0)
  shippingAmount    Int               @default(0)
  // F3C.2 — Kargo ucreti SNAPSHOT'i (siparis aninda magaza tarifesinden hesaplanan
  // tutarin kaynagi ve plan kimligi). Tutar shippingAmount'tadir; bu alanlar
  // izlenebilirlik icindir. Provider canli quote DEGILDIR (bkz. ADR-036).
  shippingCurrency     String?
  shippingSource       ShippingRateSource?
  shippingRatePlanId   String?
  shippingRatePlanName String?
  // TODO-125 (ADR-047) — Checkout'ta SEÇİLEN kargo sağlayıcı/seçenek SNAPSHOT'i.
  // Tarihsel sipariş, config sonradan değişse bile sabit kalsın diye sağlayıcı
  // görünüm bilgisi de yazılır. shippingProvider = taşıyıcı kimliği (enum),
  // shippingProviderName = görünen ad, shippingLogoUrl = public logo (secret DEĞİL),
  // shippingEtaText = tahmini teslim metni. ratePlanName service/method adıdır.
  shippingProvider     ShippingProviderType?
  shippingProviderName String?
  shippingLogoUrl      String?
  shippingEtaText      String?
  taxAmount         Int               @default(0)
  totalAmount       Int               @default(0)
  placedAt          DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  // Fatura kimlik bilgileri (F3B.2). Fatura ADRESI OrderAddress(type=BILLING)
  // kaydinda tutulur; burada yalnizca fatura tipi + vergi/kimlik kimlik alanlari
  // bulunur. Bireysel: billingTaxId = T.C. Kimlik No (11 hane). Kurumsal: firma
  // unvani + vergi dairesi + vergi no. PII gereksiz log/event metadata'ya yazilmaz.
  billingType       BillingType?
  billingName       String?
  billingTaxId      String?
  billingCompanyName String?
  billingTaxOffice  String?
  billingTaxNumber  String?
  billingEmail      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  store        Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines        OrderLine[]
  addresses    OrderAddress[]
  events       OrderEvent[]
  reservations InventoryReservation[]
  paymentAttempts PaymentAttempt[]
  paymentEvents   PaymentProviderEvent[]
  shipments       Shipment[]
  shipmentQuotes  ShipmentQuote[]
  // F4A — Siparis indirim snapshot'lari + kampanya kullanim kayitlari.
  discounts       OrderDiscount[]
  redemptions     CampaignRedemption[]
  customerCoupons CustomerCoupon[]

  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([customerId])
  @@index([status])
}

model OrderLine {
  id              String   @id @default(cuid())
  storeId         String
  orderId         String
  productId       String
  variantId       String
  sku             String
  title           String
  variantTitle    String
  quantity        Int
  unitPriceAmount Int
  totalAmount     Int
  currency        String
  createdAt       DateTime @default(now())

  store        Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant      ProductVariant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  reservations InventoryReservation[]

  @@index([storeId])
  @@index([orderId])
  @@index([variantId])
}

model OrderAddress {
  id           String      @id @default(cuid())
  storeId      String
  orderId      String
  type         AddressType
  fullName     String
  phone        String?
  countryCode  String
  city         String
  district     String?
  addressLine1 String
  addressLine2 String?
  postalCode   String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([type])
}

model OrderEvent {
  id          String   @id @default(cuid())
  storeId     String
  orderId     String
  type        String
  message     String?
  metadata    Json?
  actorUserId String?
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([type])
}

model InventoryReservation {
  id          String                     @id @default(cuid())
  storeId     String
  orderId     String
  orderLineId String
  variantId   String
  quantity    Int
  status      InventoryReservationStatus @default(ACTIVE)
  expiresAt   DateTime?
  releasedAt  DateTime?
  consumedAt  DateTime?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderLine OrderLine      @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([storeId])
  @@index([orderId])
  @@index([orderLineId])
  @@index([variantId])
  @@index([status])
}

// F3B.2 Payment Operations Foundation.
// Saglayici credential'lari yalniz ciphertext (apiKeyCipher/secretKeyCipher/
// webhookSecretCipher) olarak saklanir; duz metin DB'ye asla yazilmaz, client'a
// asla maskesiz donmez. Canli odeme bu fazda YOK; provider-ready operasyon katmani.
model PaymentProviderConfig {
  id                  String                @id @default(cuid())
  storeId             String
  provider            PaymentProviderType
  displayName         String
  status              PaymentProviderStatus @default(DISABLED)
  mode                PaymentProviderMode   @default(TEST)
  priority            Int                   @default(100)
  supportedMethods    PaymentMethodType[]
  supportedCurrencies String[]
  minAmount           Int?
  maxAmount           Int?
  threeDsMode         ThreeDsMode           @default(DISABLED)
  installmentEnabled  Boolean               @default(false)
  fallbackEnabled     Boolean               @default(false)
  merchantId          String?
  callbackUrl         String?
  apiKeyCipher        String?
  secretKeyCipher     String?
  webhookSecretCipher String?
  lastTestStatus      String?
  lastTestMessage     String?
  lastTestAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  store    Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  attempts PaymentAttempt[]
  events   PaymentProviderEvent[]

  @@unique([storeId, provider, mode])
  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, priority])
}

model PaymentAttempt {
  id                  String               @id @default(cuid())
  storeId             String
  orderId             String
  providerConfigId    String
  provider            PaymentProviderType
  mode                PaymentProviderMode
  method              PaymentMethodType
  amount              Int
  currency            String
  status              PaymentAttemptStatus @default(CREATED)
  threeDsApplied      Boolean              @default(false)
  scenario            String?
  // Odeme gozlemlenebilirligi (F3B.2). Full PAN/CVC ASLA saklanmaz; yalniz
  // turetilmis guvenli alanlar: kart markasi + son 4 hane + taksit sayisi.
  installmentCount    Int                  @default(1)
  cardBrand           String?
  cardLast4           String?
  // providerReference = saglayici islem (transaction) referansi.
  providerReference   String?
  failureCode         String?
  failureMessage      String?
  paidAt              DateTime?
  failedAt            DateTime?
  // Kisa omurlu public odeme erisim token'inin hash'i; plain token DB'ye yazilmaz.
  accessTokenHash     String?
  accessTokenExpiresAt DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerConfig PaymentProviderConfig  @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  events         PaymentProviderEvent[]

  @@index([storeId])
  @@index([orderId])
  @@index([providerConfigId])
  @@index([status])
  @@index([accessTokenHash])
}

model PaymentProviderEvent {
  id               String                   @id @default(cuid())
  storeId          String
  providerConfigId String?
  attemptId        String?
  orderId          String?
  provider         PaymentProviderType
  type             PaymentProviderEventType
  // Provider/webhook external event id varsa set edilir; internal eventlerde null.
  eventId          String?
  message          String?
  metadata         Json?
  createdAt        DateTime                 @default(now())

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  providerConfig PaymentProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: SetNull)
  attempt        PaymentAttempt?        @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  order          Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([storeId, provider, eventId], map: "payment_provider_event_unique_external_event")
  @@index([storeId])
  @@index([providerConfigId])
  @@index([attemptId])
  @@index([orderId])
  @@index([type])
}

// ─────────────────────── F3C.1 Shipping provider foundation ───────────────────────

model ShippingProviderConfig {
  id                 String                 @id @default(cuid())
  storeId            String
  provider           ShippingProviderType
  mode               ShippingProviderMode   @default(TEST)
  status             ShippingProviderStatus @default(DISABLED)
  displayName        String
  // F3C.5 (TODO-121) — Provider logo (public, secret DEGIL). UI'da liste/detay/ozet
  // kartinda gosterilir; bozuk/eksik URL'de provider initials fallback uygulanir.
  // logoStorageKey ileride object-store entegrasyonu icin TODO (su an dis URL).
  logoUrl            String?
  logoAlt            String?
  // Destructive/costly operasyon guard'lari. Hepsi varsayilan KAPALI; canli
  // createOrder/createbarcode/acceptOffer ancak ilgili env flag + bu alan + request
  // explicitConfirm uclusu saglaninca calisir (aksi halde 409).
  // Plus Command / createRecipient guard'i (paketleme öncesi varış şube tespiti).
  allowRecipientCreate Boolean              @default(false)
  allowOrderCreate   Boolean                @default(false)
  allowBarcodeCreate Boolean                @default(false)
  allowLabelPurchase Boolean                @default(false)
  // TODO-094B — son test "durumu". connectionStatus degerleri: OK/FAILED/HTTP_DISABLED/
  // SKIPPED (null => UNTESTED). HTTP transport kapaliyken test ASLA OK yazmaz.
  lastTestedAt       DateTime?
  lastTestStatus     String?
  lastErrorCode      String?
  // Son GERCEK provider HTTP testinin meta'si. Transport kapaliyken httpStatus null kalir.
  lastProviderHttpStatus Int?
  lastProviderTestType   String?
  // TODO-104 — provider webhook guvenligi. webhookToken URL yol parcasidir (config
  // cozumleme kimligi; TEK BASINA YETKI VERMEZ — HMAC imza her istekte zorunlu).
  // Secret AES-256-GCM ciphertext olarak saklanir (SHIPPING_ENCRYPTION_KEY);
  // response'a ASLA donmez, yalniz rotate aninda BIR KEZ plain doner (ADR-035 deseni).
  webhookToken        String?               @unique
  webhookSecretCipher String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  store       Store                        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  credentials ShippingProviderCredential[]
  shipments   Shipment[]
  quotes      ShipmentQuote[]
  webhookInbox ShipmentWebhookInbox[]

  @@unique([storeId, provider, mode])
  @@index([storeId])
  @@index([storeId, status])
}

model ShippingProviderCredential {
  id                       String                 @id @default(cuid())
  providerConfigId         String
  type                     ShippingCredentialType @default(DEFAULT)
  // Secret alanlar AES-256-GCM ciphertext olarak saklanir; duz metin ASLA yazilmaz.
  // DHL IDENTITY tipi ayrica customerNumber/customerPassword tutar.
  encryptedKey             String?
  encryptedSecret          String?
  encryptedCustomerNumber  String?
  encryptedCustomerPassword String?
  identityType             Int?
  // maskedKey yalnizca son-4 gosterimi icin; tam secret degildir.
  maskedKey                String?
  configured               Boolean                @default(false)
  lastTestedAt             DateTime?
  lastTestStatus           String?
  lastErrorCode            String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([providerConfigId, type])
  @@index([providerConfigId])
}

model Shipment {
  id                   String               @id @default(cuid())
  storeId              String
  orderId              String
  providerConfigId     String
  provider             ShippingProviderType
  externalOrderId      String?
  externalShipmentId   String?
  externalInvoiceId    String?
  referenceId          String
  status               ShipmentStatus       @default(DRAFT)
  shipmentStatusCode   Int?
  trackingNumber       String?
  trackingUrl          String?
  labelUrl             String?
  // Yalnizca sanitize edilmis barkod ozeti (pieceNumber + value); JWT/secret icermez.
  barcodeJsonSafe      Json?
  pieceCount           Int                  @default(1)
  totalKg              Float                @default(0)
  totalDesi            Float                @default(0)
  packagingType        Int?
  shipmentServiceType  Int?
  paymentType          Int?
  deliveryType         Int?
  recipientName        String?
  recipientEmail       String?
  recipientPhone       String?
  recipientCityCode    Int?
  recipientDistrictCode Int?
  recipientCityName    String?
  recipientDistrictName String?
  recipientAddress     String?
  // TODO-129 — zamanlanmis shipment sync worker metadata'si (provider-agnostic).
  // lastSyncAt = son sync DENEMESI (basari/hata farketmez; stale-after secimi bunu esas alir).
  // nextSyncAt = hata backoff'u (null => hemen secilebilir). syncAttempts = ARDISIK hata
  // sayaci (basarida sifirlanir; MAX_ATTEMPTS ustunu worker SECMEZ, manuel sync calisir).
  // lastSyncErrorCode = sanitize hata kodu (or. PROVIDER_QUERY_FAILED,
  // PROVIDER_SYNC_UNSUPPORTED, PROVIDER_DISABLED); raw payload/secret ASLA yazilmaz.
  lastSyncAt           DateTime?
  nextSyncAt           DateTime?
  syncAttempts         Int                  @default(0)
  lastSyncErrorCode    String?
  // TODO-124 — son barkod denemesinin SINIFLANDIRILMIS hata kodu (or.
  // DESTINATION_BRANCH_NOT_FOUND, PROVIDER_ERROR). Basarili barkod/pending ve
  // varis eslemesi onarimi (repair-destination) bunu SIFIRLAR. TODO-123 retry
  // worker'i DESTINATION_BRANCH_NOT_FOUND'u admin duzeltmesine kadar SKIP etmelidir.
  // Raw saglayici mesaji/secret ASLA yazilmaz; yalniz kisa sanitize kod.
  lastBarcodeErrorCode String?
  // TODO-123 — barkod retry/backoff metadata'si (TODO-129 sync alanlarindan AYRIDIR;
  // barkod olusturma ile durum senkronu farkli yasam donguleridir). barcodeRetryCount =
  // ardisik TRANSIENT (retryable) hata sayaci; basarili barkod/pending SIFIRLAR.
  // barcodeNextRetryAt = backoff (null => zamanlanmadi; worker SECMEZ). barcodeLastAttemptAt =
  // son barkod DENEMESI ani. barcodeRetryBlockedReason = otomatik retry BLOK nedeni:
  // "DATA_FIX" (adres/varis eslemesi duzeltilmeli — TODO-124/139), "TERMINAL" (kalici/
  // desteklenmeyen), "MAX_ATTEMPTS" (transient limit doldu). null => bloklu degil.
  // lastBarcodeErrorCode ("ne oldu") ile barcodeRetryBlockedReason ("neden otomatik
  // denenmiyor") AYRIDIR. Adres/varis onarimi (TODO-124/139) bu alanlari sifirlar.
  barcodeRetryCount        Int       @default(0)
  barcodeNextRetryAt       DateTime?
  barcodeLastAttemptAt     DateTime?
  barcodeRetryBlockedReason String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Restrict)
  events         ShipmentEvent[]

  @@unique([storeId, referenceId])
  @@index([storeId])
  @@index([orderId])
  @@index([providerConfigId])
  @@index([status])
  // TODO-129 — worker uygun gonderi secimi (status taramasi + backoff/stale siralamasi).
  @@index([status, nextSyncAt])
  @@index([status, lastSyncAt])
  // TODO-123 — barkod retry worker'inin uygun gonderi secimi (status + backoff siralamasi).
  @@index([status, barcodeNextRetryAt])
  @@index([lastBarcodeErrorCode, barcodeNextRetryAt])
}

model ShipmentEvent {
  id          String               @id @default(cuid())
  storeId     String
  shipmentId  String
  provider    ShippingProviderType
  eventType   ShipmentEventType
  statusCode  Int?
  statusText  String?
  location    String?
  occurredAt  DateTime?
  trackingUrl String?
  // Yalnizca sanitize edilmis saglayici payload ozeti; secret/JWT/Authorization icermez.
  rawSafeJson Json?
  createdAt   DateTime             @default(now())

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([shipmentId])
  @@index([eventType])
}

// TODO-104 — Webhook idempotency/replay inbox'i. Imzasi GECERLI her teslimat
// (providerConfigId, eventKey) ile BIR KEZ kaydedilir; unique ihlali = duplicate →
// yeni ShipmentEvent YAZILMAZ (idempotent). Gecersiz imzali istekler buraya
// YAZILMAZ (DB flood/DoS onlemi; yalniz log). statusText sanitize ozet tasir;
// secret/imza/raw payload ASLA saklanmaz (payloadHash sha256 ozetidir).
model ShipmentWebhookInbox {
  id               String                 @id @default(cuid())
  storeId          String
  providerConfigId String
  provider         ShippingProviderType
  eventKey         String
  payloadHash      String
  outcome          ShipmentWebhookOutcome @default(ACCEPTED)
  shipmentId       String?
  statusCode       Int?
  statusText       String?
  createdAt        DateTime               @default(now())

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@unique([providerConfigId, eventKey])
  @@index([storeId])
  @@index([shipmentId])
}

model ShipmentQuote {
  id               String               @id @default(cuid())
  storeId          String
  orderId          String?
  providerConfigId String
  provider         ShippingProviderType
  amountMinor      Int
  currency         String               @default("TRY")
  // Yalnizca sanitize edilmis ucret kalemleri ozeti; secret icermez.
  rawSafeJson      Json?
  createdAt        DateTime             @default(now())

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order          Order?                 @relation(fields: [orderId], references: [id], onDelete: SetNull)
  providerConfig ShippingProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([orderId])
  @@index([providerConfigId])
}

// ─────────────────────── F3C.2 Shipping price engine (store tarife) ───────────────────────
// Magaza bazli kargo tarife plani. Kargo ucreti bu plan + kurallar uzerinden
// hesaplanir; SAGLAYICI canli quote DEGILDIR (bkz. ADR-036). Tek default guard
// uygulama katmanindadir (Prisma partial unique olmadigi icin set-default
// transaction'inda digerleri kapatilir).
model ShippingRatePlan {
  id                         String                  @id @default(cuid())
  storeId                    String
  // Operasyon sağlayıcısıyla gevsek iliskilendirme (UI/rapor icin); fiyat etkisi YOK.
  provider                   ShippingProviderType?
  name                       String
  status                     ShippingRatePlanStatus  @default(ACTIVE)
  isDefault                  Boolean                 @default(false)
  pricingMode                ShippingRatePricingMode @default(FIXED)
  currency                   String                  @default("TRY")
  fixedAmountMinor           Int?
  freeShippingThresholdMinor Int?
  // TODO-125 (ADR-047) — Checkout kargo seçeneği kartında gösterilecek tahmini
  // teslim metni (ör. "2-3 iş günü"). PUBLIC, opsiyonel; sipariş snapshot'ına yazılır.
  deliveryEstimate           String?
  validFrom                  DateTime?
  validTo                    DateTime?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  store      Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rules      ShippingRateRule[]
  tiers      ShippingRateTier[]
  zones      ShippingRateZone[]
  surcharges ShippingSurcharge[]

  @@index([storeId])
  @@index([storeId, status])
}

// F3C.2 revizyon — Aylik gonderi hacmi segmenti / sozlesme grubu (DHL Tarife I/II/III).
// Bir kural tierId ile bu segmente baglanir; tier secimi monthlyShipmentCount'a gore
// yapilir (bilinmiyorsa en kucuk sortOrder; ADR-044). storeId yok — plan'a kapsali.
model ShippingRateTier {
  id                 String   @id @default(cuid())
  ratePlanId         String
  name               String
  monthlyShipmentMin Int?
  monthlyShipmentMax Int?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  ratePlan ShippingRatePlan   @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  rules    ShippingRateRule[]

  @@index([ratePlanId])
}

// F3C.2 revizyon — Mesafe/bolge zonu (Aras sehir-ici/yakin/kisa/orta/uzak/KKTC/MOBILE).
// code plan icinde unique. Kural zoneId ile baglanir; ince geo (city/district) ayrica
// ShippingRateRule uzerinde korunur. minDistanceKm/maxDistanceKm ilerideki firma bolge
// tablolari icin opsiyonel.
model ShippingRateZone {
  id            String   @id @default(cuid())
  ratePlanId    String
  code          String
  name          String
  minDistanceKm Decimal? @db.Decimal(10, 2)
  maxDistanceKm Decimal? @db.Decimal(10, 2)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ratePlan ShippingRatePlan   @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  rules    ShippingRateRule[]

  @@unique([ratePlanId, code])
  @@index([ratePlanId])
}

// F3C.2 revizyon — Ek hizmet bedelleri (SMS bildirim, taşıma güvencesi, mobil alan,
// hamaliye, agir gonderi, kapida odeme farki). chargeType FLAT/PER_KG/PER_DESI/...
// olabilir. isOptional=false ise her quote'a eklenir; true ise conditionJsonSafe
// degerlendirilir (SQL-injection riski yok; saf JSON, sadece engine tarafindan okunur).
model ShippingSurcharge {
  id                String             @id @default(cuid())
  ratePlanId        String
  code              String
  name              String
  chargeType        ShippingChargeType @default(FLAT)
  amountMinor       Int?
  unitAmountMinor   Int?
  conditionJsonSafe Json?
  isOptional        Boolean            @default(false)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  ratePlan ShippingRatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([ratePlanId, code])
  @@index([ratePlanId])
}

model ShippingRateRule {
  id               String             @id @default(cuid())
  ratePlanId       String
  storeId          String
  tierId           String?
  zoneId           String?
  minDesi          Decimal?           @db.Decimal(10, 2)
  maxDesi          Decimal?           @db.Decimal(10, 2)
  minWeightKg      Decimal?           @db.Decimal(10, 3)
  maxWeightKg      Decimal?           @db.Decimal(10, 3)
  cityCode         String?
  districtCode     String?
  regionCode       String?
  // chargeType FLAT (varsayilan) mevcut amountMinor yolunu birebir korur. Yeni
  // tipler unitAmountMinor / baseAmountMinor / baseThreshold kullanir. amountMinor
  // artik nullable (FLAT disinda zorunlu degil); mevcut veriler backfill ile korunur.
  chargeType       ShippingChargeType @default(FLAT)
  amountMinor      Int?
  unitAmountMinor  Int?
  baseAmountMinor  Int?
  baseThreshold    Decimal?           @db.Decimal(10, 2)
  // Legacy/simple-extra: yeni gelismis hesabin merkezi DEGIL; ek ucretler
  // ShippingSurcharge ile yonetilir (ADR-044 revizyon). Geriye uyumluluk icin korunur.
  extraAmountMinor Int?
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  store    Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ratePlan ShippingRatePlan  @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)
  tier     ShippingRateTier? @relation(fields: [tierId], references: [id], onDelete: SetNull)
  zone     ShippingRateZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([ratePlanId])
  @@index([cityCode, districtCode])
  @@index([storeId])
  @@index([tierId])
  @@index([zoneId])
}

// ─────────────────────── F4A Campaigns & Coupons MVP ───────────────────────
// Kampanya: magaza-scoped indirim tanimi. discountValue PERCENT'te 1-100 tam
// sayi yuzdedir; FIXED_AMOUNT'ta minor unit (kurus) tutardir. usageCount toplam
// kullanim limiti icin ATOMIK sayactir (siparis transaction'inda kosullu
// UPDATE ile artirilir; limit asilirsa siparis reddedilir — ADR-058).
model Campaign {
  id                     String               @id @default(cuid())
  storeId                String
  name                   String
  description            String?
  status                 CampaignStatus       @default(DRAFT)
  type                   CampaignType
  discountType           CampaignDiscountType
  discountValue          Int
  maxDiscountAmountMinor Int?
  minOrderAmountMinor    Int?
  startsAt               DateTime?
  endsAt                 DateTime?
  totalUsageLimit        Int?
  perCustomerUsageLimit  Int?
  usageCount             Int                  @default(0)
  stackable              Boolean              @default(false)
  priority               Int                  @default(0)
  isPublic               Boolean              @default(true)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  store          Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coupons         Coupon[]
  products        CampaignProduct[]
  categories      CampaignCategory[]
  redemptions     CampaignRedemption[]
  orderDiscounts  OrderDiscount[]
  customerCoupons CustomerCoupon[]

  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, type])
}

// Kupon kodu: store scope'unda normalizedCode UNIQUE (farkli magazalar ayni
// kodu kullanabilir). normalizedCode = trim + locale-BAGIMSIZ uppercase
// (TR-I tuzagina karsi izinli karakterler [A-Z0-9_-]). startsAt/endsAt
// kampanya penceresini DARALTAN opsiyonel override'dir.
model Coupon {
  id                    String       @id @default(cuid())
  storeId               String
  campaignId            String
  code                  String
  normalizedCode        String
  status                CouponStatus @default(ACTIVE)
  totalUsageLimit       Int?
  perCustomerUsageLimit Int?
  usageCount            Int          @default(0)
  startsAt              DateTime?
  endsAt                DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  store           Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign        Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  redemptions     CampaignRedemption[]
  orderDiscounts  OrderDiscount[]
  customerCoupons CustomerCoupon[]

  @@unique([storeId, normalizedCode])
  @@index([storeId])
  @@index([campaignId])
}

// Kampanya urun kapsami. Bos kapsam = tum sepet. Scope id'leri ayni store'a
// ait olmalidir (uygulama katmaninda dogrulanir; storeId kolonu izolasyon
// sorgulari icindir).
model CampaignProduct {
  campaignId String
  productId  String
  storeId    String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([campaignId, productId])
  @@index([storeId])
  @@index([productId])
}

model CampaignCategory {
  campaignId String
  categoryId String
  storeId    String
  createdAt  DateTime @default(now())

  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([campaignId, categoryId])
  @@index([storeId])
  @@index([categoryId])
}

// Kullanim kaydi: siparis olusturma transaction'inda yazilir; siparis basina
// kampanya BIR KEZ (unique). Siparis sonradan iptal/refund olsa da kayit
// TARIHSEL kalir (kompanzasyon deseni yok — ADR-058'de dokumante sinirlama).
// email: misafir checkout'ta per-customer limit dayanagi (customerId yoksa).
model CampaignRedemption {
  id                  String   @id @default(cuid())
  storeId             String
  campaignId          String
  couponId            String?
  orderId             String
  customerId          String?
  email               String?
  discountAmountMinor Int
  createdAt           DateTime @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  coupon   Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([campaignId, orderId])
  @@index([storeId])
  @@index([couponId])
  @@index([campaignId, customerId])
  @@index([campaignId, email])
  @@index([orderId])
}

// Siparis indirim SNAPSHOT satiri (immutable; siparis olusturulduktan sonra
// degistirilmez — ADR-058). Kampanya/kupon sonradan silinse/degisse bile
// siparis gecmisi sabit kalir; bu yuzden label/code/discountType kopyalanir.
model OrderDiscount {
  id                  String               @id @default(cuid())
  storeId             String
  orderId             String
  campaignId          String?
  couponId            String?
  code                String?
  label               String
  discountType        CampaignDiscountType
  discountValue       Int
  discountAmountMinor Int
  scopeSummary        Json?
  createdAt           DateTime             @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  coupon   Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([orderId])
  @@index([campaignId])
}

// F4A.3 — Musteri kupon cuzdani (ADR-060). Bir kupon satiri BIR musteri
// (customerId) VEYA bir email icin tutulur. status yasam dongusu:
// AVAILABLE -> APPLIED (sepette "Kullan") -> USED (siparis basarili) / geri
// AVAILABLE ("Kaldir"); REVOKED admin geri-alimidir. KAYNAK DOGRUSU indirim
// tutari icin DEGILDIR — indirim yine couponCode + motordan gelir; bu tablo
// yalnizca cuzdan/atama/claim state'idir. Store-scoped; cross-store gorunmez.
model CustomerCoupon {
  id         String               @id @default(cuid())
  storeId    String
  couponId   String
  campaignId String
  customerId String?
  email      String?
  status     CustomerCouponStatus @default(AVAILABLE)
  source     CustomerCouponSource
  claimedAt  DateTime             @default(now())
  appliedAt  DateTime?
  usedAt     DateTime?
  orderId    String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coupon   Coupon    @relation(fields: [couponId], references: [id], onDelete: Cascade)
  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Ayni kupon ayni musteri/email icin TEK satir (lifecycle in-place gunceller).
  // Postgres NULL-distinct oldugundan customerId=null satirlar email kisitiyla,
  // email=null satirlar customerId kisitiyla korunur; uygulama katmani da dedup yapar.
  @@unique([storeId, couponId, customerId])
  @@unique([storeId, couponId, email])
  @@index([storeId])
  @@index([couponId])
  @@index([campaignId])
  @@index([storeId, customerId, status])
  @@index([storeId, email, status])
}
